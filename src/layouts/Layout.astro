---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Aurora Watch — Real-time aurora tracking, livestreams, and space weather data.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Karantina:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} | Aurora Watch</title>
  </head>
  <body>
    <div class="site-wrapper">
      <!-- Animated aurora background -->
      <div class="aurora-bg">
        <div class="aurora-layer aurora-1"></div>
        <div class="aurora-layer aurora-2"></div>
        <div class="aurora-layer aurora-3"></div>
        <div class="stars"></div>
      </div>

      <header class="site-header">
        <div class="header-inner">
          <a href={`${base}`} class="site-title">AURORA WATCH</a>
          <nav class="site-nav">
            <a href={`${base}`} class="nav-link">LIVESTREAMS</a>
            <a href={`${base}about`} class="nav-link">ABOUT</a>
          </nav>
        </div>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <p>Data sourced from <a href="https://www.swpc.noaa.gov/" target="_blank" rel="noopener">NOAA Space Weather Prediction Center</a></p>
          <p>Aurora Watch &copy; {new Date().getFullYear()} — For educational use</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg-dark: #0d0e18;
    --bg-card: #101431;
    --bg-card-alt: #0f1a2e;
    --border-color: rgba(255, 255, 255, 0.25);
    --border-glow: rgba(120, 80, 255, 0.5);
    --text-white: #ffffff;
    --text-muted: rgba(255, 255, 255, 0.6);
    --text-dim: rgba(255, 255, 255, 0.35);
    --accent-green: #39ff8a;
    --accent-purple: #a855f7;
    --accent-cyan: #22d3ee;
    --accent-magenta: #e879f9;
    --accent-yellow: #fbbf24;
    --accent-red: #f87171;
    --font-display: 'Karantina', serif;
    --font-body: 'Inter', sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg-dark);
    color: var(--text-white);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .site-wrapper {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ─── Aurora animated background ─── */
  .aurora-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 35%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 40% 8%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 20%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 5%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 28%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 12%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 50%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 65%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 60% 45%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 55%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 5% 80%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 88%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 75% 78%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 95% 70%, rgba(255,255,255,0.5) 0%, transparent 100%);
  }

  .aurora-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    animation: aurora-drift 18s ease-in-out infinite;
  }

  .aurora-1 {
    width: 120%;
    height: 500px;
    top: -100px;
    left: -20%;
    background: radial-gradient(ellipse, rgba(57, 255, 138, 0.18) 0%, rgba(34, 211, 238, 0.08) 50%, transparent 70%);
    animation-duration: 22s;
    animation-delay: 0s;
  }

  .aurora-2 {
    width: 100%;
    height: 600px;
    top: -150px;
    right: -10%;
    background: radial-gradient(ellipse, rgba(168, 85, 247, 0.2) 0%, rgba(232, 121, 249, 0.08) 50%, transparent 70%);
    animation-duration: 18s;
    animation-delay: -6s;
    animation-direction: reverse;
  }

  .aurora-3 {
    width: 80%;
    height: 400px;
    top: 0;
    left: 20%;
    background: radial-gradient(ellipse, rgba(34, 211, 238, 0.12) 0%, rgba(57, 255, 138, 0.06) 50%, transparent 70%);
    animation-duration: 25s;
    animation-delay: -12s;
  }

  @keyframes aurora-drift {
    0%, 100% { transform: translateY(0) scaleX(1) scaleY(1); opacity: 0.7; }
    25% { transform: translateY(40px) scaleX(1.05) scaleY(0.95); opacity: 1; }
    50% { transform: translateY(20px) scaleX(0.98) scaleY(1.08); opacity: 0.85; }
    75% { transform: translateY(-20px) scaleX(1.02) scaleY(0.97); opacity: 0.9; }
  }

  /* ─── Header ─── */
  .site-header {
    position: relative;
    z-index: 10;
    padding: 32px 48px 0;
  }

  .header-inner {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .site-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 700;
    color: var(--text-white);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-shadow:
      0 0 40px rgba(57, 255, 138, 0.5),
      0 0 80px rgba(168, 85, 247, 0.3);
    line-height: 1;
    transition: text-shadow 0.3s;
  }

  .site-title:hover {
    text-shadow:
      0 0 60px rgba(57, 255, 138, 0.8),
      0 0 120px rgba(168, 85, 247, 0.5);
  }

  .site-nav {
    display: flex;
    gap: 40px;
    padding-left: 4px;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 48px);
    font-weight: 400;
    color: var(--text-white);
    text-decoration: none;
    letter-spacing: 0.06em;
    position: relative;
    transition: color 0.2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-green), var(--accent-purple));
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .nav-link:hover {
    color: var(--accent-green);
  }

  /* ─── Main ─── */
  .site-main {
    position: relative;
    z-index: 10;
    flex: 1;
    padding: 40px 48px 64px;
  }

  /* ─── Footer ─── */
  .site-footer {
    position: relative;
    z-index: 10;
    padding: 24px 48px;
    border-top: 1px solid var(--border-color);
    background: rgba(10, 11, 20, 0.5);
    backdrop-filter: blur(8px);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }

  .footer-inner a {
    color: var(--accent-green);
    text-decoration: none;
  }

  .footer-inner a:hover {
    text-decoration: underline;
  }

  /* ─── Card base ─── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .card:hover {
    border-color: var(--border-glow);
    box-shadow: 0 0 24px rgba(120, 80, 255, 0.15);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.08em;
    color: var(--text-white);
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  /* ─── Utility ─── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 2px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .badge-green  { background: rgba(57, 255, 138, 0.15); color: var(--accent-green); border: 1px solid rgba(57, 255, 138, 0.4); }
  .badge-yellow { background: rgba(251, 191, 36, 0.15); color: var(--accent-yellow); border: 1px solid rgba(251, 191, 36, 0.4); }
  .badge-red    { background: rgba(248, 113, 113, 0.15); color: var(--accent-red); border: 1px solid rgba(248, 113, 113, 0.4); }
  .badge-purple { background: rgba(168, 85, 247, 0.15); color: var(--accent-purple); border: 1px solid rgba(168, 85, 247, 0.4); }
  .badge-cyan   { background: rgba(34, 211, 238, 0.15); color: var(--accent-cyan); border: 1px solid rgba(34, 211, 238, 0.4); }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-anim 1.5s ease-in-out infinite;
  }

  @keyframes pulse-anim {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .site-header { padding: 24px 20px 0; }
    .site-main   { padding: 24px 20px 48px; }
    .site-footer { padding: 20px; }
    .footer-inner { flex-direction: column; text-align: center; }
    .site-nav { gap: 24px; }
  }
</style>
