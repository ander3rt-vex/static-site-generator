---
export interface Props {
  title: string;
  description?: string;
  bgImage?: string;
}
const {
  title,
  description = 'Aurora Watch — Real-time aurora tracking, livestreams, and space weather data.',
  bgImage,
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Karantina:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} | Aurora Watch</title>
  </head>
  <body>
    <div class={`site-wrapper ${bgImage ? 'has-photo-bg' : ''}`}>

      <!-- Photo background (Figma images) -->
      {bgImage && (
        <div class="photo-bg" style={`background-image: url('${bgImage}')`}></div>
      )}

      <!-- Animated aurora fallback (used when no photo) -->
      {!bgImage && (
        <div class="aurora-bg">
          <div class="aurora-layer aurora-1"></div>
          <div class="aurora-layer aurora-2"></div>
          <div class="aurora-layer aurora-3"></div>
          <div class="stars"></div>
        </div>
      )}

      <!-- Dark overlay for readability -->
      <div class="overlay"></div>

      <header class="site-header">
        <a href={`${base}`} class="site-title">AURORA WATCH</a>
        <nav class="site-nav">
          <a href={`${base}`} class="nav-link">LIVESTREAMS</a>
          <a href={`${base}about`} class="nav-link">ABOUT</a>
        </nav>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-inner">
          <p>Data from <a href="https://www.swpc.noaa.gov/" target="_blank" rel="noopener">NOAA SWPC</a> · Photos from Figma / <a href="https://unsplash.com" target="_blank" rel="noopener">Unsplash</a></p>
          <p>Aurora Watch &copy; {new Date().getFullYear()} — Educational use only</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-dark:      #19191d;
    --bg-card:      #101431;
    --border-white: rgba(255,255,255,1);
    --border-dim:   rgba(255,255,255,0.22);
    --border-glow:  rgba(120,80,255,0.55);
    --text-white:   #ffffff;
    --text-muted:   rgba(255,255,255,0.60);
    --text-dim:     rgba(255,255,255,0.35);
    --accent-green:   #39ff8a;
    --accent-purple:  #a855f7;
    --accent-cyan:    #22d3ee;
    --accent-magenta: #e879f9;
    --accent-yellow:  #fbbf24;
    --accent-red:     #f87171;
    --font-display: 'Karantina', serif;
    --font-body:    'Inter', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-dark);
    color: var(--text-white);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Site wrapper ── */
  .site-wrapper {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Photo background (Figma images) ── */
  .photo-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
  }

  /* ── Dark overlay ── */
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: rgba(10,11,20,0.52);
  }

  .has-photo-bg .overlay {
    background: rgba(10,11,20,0.58);
  }

  /* ── Animated aurora fallback ── */
  .aurora-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 35%, rgba(255,255,255,.6) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 40% 8%, rgba(255,255,255,.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 20%, rgba(255,255,255,.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 5%, rgba(255,255,255,.8) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 28%, rgba(255,255,255,.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 50%, rgba(255,255,255,.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 45%, rgba(255,255,255,.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 55%, rgba(255,255,255,.7) 0%, transparent 100%);
  }

  .aurora-layer {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    animation: aurora-drift 18s ease-in-out infinite;
  }

  .aurora-1 {
    width: 120%; height: 500px; top: -100px; left: -20%;
    background: radial-gradient(ellipse, rgba(57,255,138,.18) 0%, rgba(34,211,238,.08) 50%, transparent 70%);
    animation-duration: 22s;
  }
  .aurora-2 {
    width: 100%; height: 600px; top: -150px; right: -10%;
    background: radial-gradient(ellipse, rgba(168,85,247,.2) 0%, rgba(232,121,249,.08) 50%, transparent 70%);
    animation-duration: 18s; animation-delay: -6s; animation-direction: reverse;
  }
  .aurora-3 {
    width: 80%; height: 400px; top: 0; left: 20%;
    background: radial-gradient(ellipse, rgba(34,211,238,.12) 0%, rgba(57,255,138,.06) 50%, transparent 70%);
    animation-duration: 25s; animation-delay: -12s;
  }

  @keyframes aurora-drift {
    0%,100% { transform: translateY(0) scaleX(1); opacity: .7; }
    25%      { transform: translateY(40px) scaleX(1.05); opacity: 1; }
    50%      { transform: translateY(20px) scaleX(.98); opacity: .85; }
    75%      { transform: translateY(-20px) scaleX(1.02); opacity: .9; }
  }

  /* ── Header ── */
  .site-header {
    position: relative;
    z-index: 10;
    padding: 40px 50px 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .site-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 128px);
    font-weight: 400;
    color: var(--text-white);
    text-decoration: none;
    letter-spacing: 0.03em;
    line-height: 1;
    text-shadow: 0 2px 40px rgba(0,0,0,.6);
    display: block;
  }

  .site-nav {
    display: flex;
    gap: 44px;
    margin-top: 4px;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.5vw, 64px);
    font-weight: 400;
    color: var(--text-white);
    text-decoration: none;
    letter-spacing: 0.04em;
    line-height: 1;
    position: relative;
    transition: color .2s;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-green), var(--accent-purple));
    transform: scaleX(0);
    transition: transform .3s;
    transform-origin: left;
  }

  .nav-link:hover { color: var(--accent-green); }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after { transform: scaleX(1); }

  /* ── Main ── */
  .site-main {
    position: relative;
    z-index: 10;
    flex: 1;
    padding: 28px 50px 56px;
  }

  /* ── Footer ── */
  .site-footer {
    position: relative;
    z-index: 10;
    padding: 18px 50px;
    border-top: 1px solid rgba(255,255,255,.12);
    background: rgba(10,11,20,.55);
    backdrop-filter: blur(10px);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }

  .footer-inner a { color: var(--accent-green); text-decoration: none; }
  .footer-inner a:hover { text-decoration: underline; }

  /* ── Shared card base ── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 3px;
    padding: 22px;
    position: relative;
    overflow: hidden;
    transition: border-color .3s, box-shadow .3s;
  }

  .card:hover {
    border-color: var(--border-glow);
    box-shadow: 0 0 28px rgba(120,80,255,.18);
  }

  /* ── Badges ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 2px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .badge-green  { background:rgba(57,255,138,.15); color:var(--accent-green);   border:1px solid rgba(57,255,138,.4); }
  .badge-yellow { background:rgba(251,191,36,.15); color:var(--accent-yellow);  border:1px solid rgba(251,191,36,.4); }
  .badge-red    { background:rgba(248,113,113,.15);color:var(--accent-red);     border:1px solid rgba(248,113,113,.4); }
  .badge-purple { background:rgba(168,85,247,.15); color:var(--accent-purple);  border:1px solid rgba(168,85,247,.4); }
  .badge-cyan   { background:rgba(34,211,238,.15); color:var(--accent-cyan);    border:1px solid rgba(34,211,238,.4); }

  .pulse-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse-anim 1.5s ease-in-out infinite;
  }

  @keyframes pulse-anim {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.4; transform:scale(.7); }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .site-header { padding: 24px 20px 0; }
    .site-main   { padding: 20px 20px 48px; }
    .site-footer { padding: 16px 20px; }
    .footer-inner { flex-direction: column; text-align: center; }
    .site-nav { gap: 20px; }
  }
</style>
