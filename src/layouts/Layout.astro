---
export interface Props {
  title: string;
  description?: string;
  bgImage?: string;
  activePage?: 'home' | 'livestreams';
}
const {
  title,
  description = 'Aurora Watch — Kp index, space weather tracking, and live aurora camera streams.',
  bgImage,
  activePage = 'home',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Karantina:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} | Aurora Watch</title>
  </head>
  <body>

    <!-- Full-bleed background photo -->
    {bgImage && <div class="page-bg" style={`background-image:url('${bgImage}')`}></div>}

    <!-- Subtle dark veil so text stays readable -->
    <div class="page-veil"></div>

    <!-- ─── HEADER (matches Figma Desktop-1 header zone) ─── -->
    <header class="site-header">
      <a href={`${base}`} class="logo">AURORA WATCH</a>
      <nav class="site-nav">
        <a href={`${base}`}          class={`nav-link ${activePage==='home'        ? 'nav-active':''}`}>HOME</a>
        <a href={`${base}livestreams`} class={`nav-link ${activePage==='livestreams' ? 'nav-active':''}`}>LIVESTREAMS</a>
      </nav>
    </header>

    <!-- Page slot -->
    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <span>Aurora Watch — educational use only</span>
      <span>Data: <a href="https://www.swpc.noaa.gov/" target="_blank" rel="noopener">NOAA SWPC</a></span>
    </footer>

  </body>
</html>

<style is:global>
/* ═══════════════════════════════════════════
   FIGMA COLOR PALETTE
   #19191D  page background
   #101431  card / nav-bar background
   #FFFFFF  text & borders
   #5F37B4  purple accent
   #934284  mauve accent
   #478F10  green accent
═══════════════════════════════════════════ */
:root {
  --bg:          #19191D;
  --card:        #101431;
  --white:       #FFFFFF;
  --purple:      #5F37B4;
  --mauve:       #934284;
  --green:       #478F10;

  /* Derived helper tints */
  --purple-glow: rgba(95,55,180,.55);
  --mauve-glow:  rgba(147,66,132,.55);
  --green-glow:  rgba(71,143,16,.55);
  --white-dim:   rgba(255,255,255,.6);
  --white-faint: rgba(255,255,255,.2);

  --font-display: 'Karantina', serif;
  --font-body:    'Inter', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--white);
  font-family: var(--font-body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ─── Background photo ─── */
.page-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
}

.page-veil {
  position: fixed;
  inset: 0;
  z-index: 1;
  background: rgba(13, 12, 22, 0.48);
}

/* ─── Header ─── */
.site-header {
  position: relative;
  z-index: 20;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 40px 50px 0;
}

.logo {
  font-family: var(--font-display);
  font-size: clamp(52px, 8.9vw, 128px);
  font-weight: 400;
  color: var(--white);
  text-decoration: none;
  letter-spacing: .03em;
  line-height: 1;
  /* subtle text shadow so it pops off the photo */
  text-shadow: 0 2px 32px rgba(0,0,0,.7), 0 0 60px rgba(95,55,180,.35);
}

.site-nav {
  display: flex;
  gap: 40px;
  padding-top: 18px; /* vertically align with top of logo cap */
}

.nav-link {
  font-family: var(--font-display);
  font-size: clamp(26px, 4.4vw, 64px);
  font-weight: 400;
  color: var(--white);
  text-decoration: none;
  letter-spacing: .04em;
  line-height: 1;
  transition: color .2s;
  position: relative;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--green), var(--purple));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s;
}

.nav-link:hover { color: rgba(255,255,255,.75); }
.nav-link:hover::after,
.nav-active::after { transform: scaleX(1); }

/* ─── Main ─── */
.site-main {
  position: relative;
  z-index: 10;
  flex: 1;
}

/* ─── Footer ─── */
.site-footer {
  position: relative;
  z-index: 20;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  padding: 16px 50px;
  font-size: 12px;
  color: var(--white-dim);
  border-top: 1px solid var(--white-faint);
  background: rgba(13,12,22,.55);
  backdrop-filter: blur(10px);
}

.site-footer a { color: rgba(71,143,16,.9); text-decoration: none; }
.site-footer a:hover { text-decoration: underline; }

/* ─── Shared card ─── */
.card {
  background: var(--card);
  border: 1px solid var(--white-faint);
  border-radius: 3px;
  padding: 22px;
}

/* ─── Badges ─── */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 10px;
  border-radius: 2px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .1em;
  text-transform: uppercase;
}

.badge-green  { background: rgba(71,143,16,.2);  color: #78c42a; border: 1px solid rgba(71,143,16,.5); }
.badge-purple { background: rgba(95,55,180,.2);  color: #9b7ef0; border: 1px solid rgba(95,55,180,.5); }
.badge-mauve  { background: rgba(147,66,132,.2); color: #c977b7; border: 1px solid rgba(147,66,132,.5); }
.badge-yellow { background: rgba(220,160,20,.2); color: #f0c040; border: 1px solid rgba(220,160,20,.5); }
.badge-red    { background: rgba(180,40,40,.2);  color: #f07070; border: 1px solid rgba(180,40,40,.5); }

.pulse-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: currentColor;
  animation: pulse 1.6s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:.35; transform:scale(.65); }
}

/* ─── Responsive ─── */
@media (max-width: 768px) {
  .site-header { padding: 24px 20px 0; flex-direction: column; gap: 12px; }
  .site-main   { padding: 0; }
  .site-footer { padding: 14px 20px; flex-direction: column; text-align: center; }
  .site-nav    { gap: 20px; padding-top: 0; }
}
</style>
