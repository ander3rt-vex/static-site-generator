---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const bgImage = `${base}images/aurora-bg.jpg`;
---

<Layout title="Livestreams" bgImage={bgImage}>

  <!-- ── Live Status Bar ── -->
  <div class="status-bar">
    <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
    <span class="status-text">Kp&nbsp;<strong>3</strong> · Solar Wind <strong>420&nbsp;km/s</strong> · Bz&nbsp;<strong>−4.2&nbsp;nT</strong> southward</span>
    <a class="status-link" href="https://www.swpc.noaa.gov/products/alerts-watches-and-warnings" target="_blank" rel="noopener">
      NOAA Space Weather →
    </a>
  </div>

  <!-- ── 2 × 2 Stream Grid (matches Figma card layout) ── -->
  <section class="stream-grid">

    <!-- Card 1 — Aurora Borealis LIVE! · Lapland, Finland -->
    <div class="stream-card">
      <div class="stream-embed">
        <!-- Fallback aurora photo shown behind iframe -->
        <img
          src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=800&q=80"
          alt="Aurora borealis over Lapland"
          class="card-photo"
          loading="lazy"
        />
        <iframe
          src="https://www.youtube.com/embed/live_stream?channel=UCrEfDv09Q2suoiSDt1hZIlg&autoplay=1&mute=1&modestbranding=1&rel=0"
          title="Aurora Borealis LIVE – Lapland Finland"
          frameborder="0"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
        <div class="embed-label">
          <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
        </div>
      </div>
      <div class="stream-footer">
        <div class="stream-loc">📍 Lapland, Finland · 68°N</div>
        <div class="stream-info-text">Aurora Borealis LIVE! — 24/7 wilderness sky camera from remote Finnish Lapland</div>
        <a class="stream-yt-link" href="https://www.youtube.com/channel/UCrEfDv09Q2suoiSDt1hZIlg" target="_blank" rel="noopener">
          Open on YouTube →
        </a>
      </div>
    </div>

    <!-- Card 2 — Explore.org Fairbanks Aurora Cam -->
    <div class="stream-card">
      <div class="stream-embed">
        <img
          src="https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=800&q=80"
          alt="Aurora borealis over mountains"
          class="card-photo"
          loading="lazy"
        />
        <iframe
          src="https://www.youtube.com/embed/O52zDyxg5QI?autoplay=1&mute=1&modestbranding=1&rel=0&loop=1&playlist=O52zDyxg5QI"
          title="Fairbanks Aurora Camera – Explore.org"
          frameborder="0"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
        <div class="embed-label">
          <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
        </div>
      </div>
      <div class="stream-footer">
        <div class="stream-loc">📍 Fairbanks, Alaska · 64°N</div>
        <div class="stream-info-text">Explore.org sky camera powered by UAF Geophysical Institute · Updates every 10 min</div>
        <a class="stream-yt-link" href="https://www.youtube.com/watch?v=O52zDyxg5QI" target="_blank" rel="noopener">
          Open on YouTube →
        </a>
      </div>
    </div>

    <!-- Card 3 — North Dakota Dual Aurora Cameras -->
    <div class="stream-card">
      <div class="stream-embed">
        <img
          src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=800&q=80"
          alt="Aurora borealis in the night sky"
          class="card-photo"
          loading="lazy"
        />
        <iframe
          src="https://www.youtube.com/embed/live_stream?channel=UC7pBM_HJbGO7IlYIAsFcKAg&autoplay=1&mute=1&modestbranding=1&rel=0"
          title="North Dakota Dual Aurora Cameras"
          frameborder="0"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
        <div class="embed-label">
          <span class="badge badge-cyan">ALL-SKY CAM</span>
        </div>
      </div>
      <div class="stream-footer">
        <div class="stream-loc">📍 Inkster, North Dakota · 48°N</div>
        <div class="stream-info-text">NoDDAC citizen science project — dual north-facing aurora cameras at Martens Observatory</div>
        <a class="stream-yt-link" href="https://www.youtube.com/channel/UC7pBM_HJbGO7IlYIAsFcKAg" target="_blank" rel="noopener">
          Open on YouTube →
        </a>
      </div>
    </div>

    <!-- Card 4 — NOAA Live Aurora Oval + Space Weather Data -->
    <div class="stream-card">
      <div class="stream-embed noaa-embed">
        <!-- NOAA real-time aurora oval map (public domain, no license) -->
        <img
          src="https://services.swpc.noaa.gov/images/animations/ovation/north/latest.jpg"
          alt="NOAA OVATION aurora oval forecast – Northern Hemisphere"
          class="card-photo noaa-map"
          loading="lazy"
          id="noaa-oval"
        />
        <!-- Southern overlay with space weather data -->
        <div class="noaa-data-overlay">
          <div class="noaa-row">
            <span class="nd-label">Kp Index</span>
            <div class="nd-kpbar">
              {[1,2,3,4,5,6,7,8,9].map(n => (
                <div class={`nd-kp-seg ${n<=3?'nd-active':n<=5?'nd-warn':n<=7?'nd-high':'nd-extreme'}`} title={`Kp ${n}`}></div>
              ))}
            </div>
            <span class="nd-val">Kp 3</span>
          </div>
          <div class="noaa-row">
            <span class="nd-label">Bz</span>
            <span class="nd-val nd-neg">−4.2 nT ↓ southward</span>
          </div>
          <div class="noaa-row">
            <span class="nd-label">Solar Wind</span>
            <span class="nd-val">420 km/s</span>
          </div>
          <div class="noaa-row">
            <span class="nd-label">Geomag Scale</span>
            <span class="badge badge-yellow">G1 Minor</span>
          </div>
        </div>
        <div class="embed-label">
          <span class="badge badge-purple">NOAA OVATION</span>
        </div>
      </div>
      <div class="stream-footer">
        <div class="stream-loc">🛰️ NOAA DSCOVR · L1 Lagrange Point</div>
        <div class="stream-info-text">Real-time aurora oval probability map + live solar wind data · Refreshed every 5 min</div>
        <a class="stream-yt-link" href="https://www.swpc.noaa.gov/communities/aurora-dashboard-experimental" target="_blank" rel="noopener">
          NOAA Aurora Dashboard →
        </a>
      </div>
    </div>

  </section>

  <!-- ── Kp Visibility Quick-Reference ── -->
  <section class="kp-quick-ref">
    <div class="kp-ref-label">AURORA VISIBILITY BY KP</div>
    <div class="kp-ref-row">
      <div class="kp-ref-item kp-3">
        <span class="kp-num">Kp 3</span>
        <span class="kp-loc">Iceland · Norway · Alaska</span>
      </div>
      <div class="kp-ref-item kp-5">
        <span class="kp-num">Kp 5</span>
        <span class="kp-loc">Scotland · S. Canada · N. US</span>
      </div>
      <div class="kp-ref-item kp-7">
        <span class="kp-num">Kp 7</span>
        <span class="kp-loc">N. Germany · Central US</span>
      </div>
      <div class="kp-ref-item kp-9">
        <span class="kp-num">Kp 9</span>
        <span class="kp-loc">S. Europe · Mid US states</span>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Status bar ── */
  .status-bar {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    background: rgba(16,20,49,.75);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 3px;
    padding: 9px 18px;
    margin-bottom: 24px;
    font-size: 13px;
  }

  .status-text { color: rgba(255,255,255,.65); flex: 1; }
  .status-text strong { color: #fff; }

  .status-link {
    color: var(--accent-cyan);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: .06em;
    white-space: nowrap;
  }
  .status-link:hover { text-decoration: underline; }

  /* ── Stream Grid — 2×2 matching Figma proportions ── */
  .stream-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 28px;
  }

  /* ── Stream Card ── */
  .stream-card {
    background: #101431;
    border: 3px solid #ffffff;
    border-radius: 3px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .3s, box-shadow .3s;
  }

  .stream-card:hover {
    border-color: rgba(168,85,247,.9);
    box-shadow: 0 0 32px rgba(120,80,255,.25);
  }

  /* ── Embed wrapper — 3:2 aspect ratio (496:331 from Figma) ── */
  .stream-embed {
    position: relative;
    width: 100%;
    padding-top: 66.73%; /* 331/496 = 66.73% */
    overflow: hidden;
    background: #060810;
  }

  /* Background aurora photo (free-use from Unsplash) */
  .card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(.7) saturate(1.3);
    z-index: 1;
  }

  .noaa-map {
    object-fit: contain;
    background: #060810;
    filter: saturate(1.5) brightness(1.1);
    padding: 8px;
  }

  /* YouTube iframe on top of photo */
  .stream-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    border: none;
    opacity: 0;
    transition: opacity .6s;
  }

  /* Show iframe once it loads */
  .stream-embed iframe.loaded,
  .stream-embed iframe:not([src=""]) {
    opacity: 1;
  }

  /* Live badge overlay */
  .embed-label {
    position: absolute;
    top: 10px;
    right: 12px;
    z-index: 5;
  }

  /* NOAA data overlay (bottom of card 4) */
  .noaa-data-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 4;
    background: linear-gradient(transparent, rgba(8,10,24,.95));
    padding: 24px 14px 12px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .noaa-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
  }

  .nd-label {
    color: rgba(255,255,255,.5);
    width: 76px;
    flex-shrink: 0;
    letter-spacing: .04em;
  }

  .nd-val { color: #fff; font-weight: 500; }
  .nd-neg { color: var(--accent-red); }

  .nd-kpbar {
    display: flex;
    gap: 2px;
    flex: 1;
    height: 8px;
    align-items: center;
  }

  .nd-kp-seg {
    flex: 1;
    height: 6px;
    border-radius: 1px;
    background: rgba(255,255,255,.08);
  }

  .nd-active  { background: rgba(57,255,138,.7); }
  .nd-warn    { background: rgba(251,191,36,.25); }
  .nd-high    { background: rgba(249,115,22,.25); }
  .nd-extreme { background: rgba(248,113,113,.25); }

  /* ── Stream footer info ── */
  .stream-footer {
    padding: 12px 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: #101431;
  }

  .stream-loc {
    font-size: 11px;
    color: rgba(255,255,255,.5);
    letter-spacing: .04em;
  }

  .stream-info-text {
    font-size: 12px;
    color: rgba(255,255,255,.75);
    line-height: 1.45;
  }

  .stream-yt-link {
    font-size: 11px;
    color: var(--accent-cyan);
    text-decoration: none;
    letter-spacing: .04em;
    margin-top: 2px;
    display: inline-block;
  }
  .stream-yt-link:hover { text-decoration: underline; }

  /* ── Kp quick reference ── */
  .kp-quick-ref {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    background: rgba(16,20,49,.7);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 3px;
    padding: 12px 20px;
  }

  .kp-ref-label {
    font-size: 9px;
    letter-spacing: .18em;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    font-weight: 600;
    white-space: nowrap;
  }

  .kp-ref-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex: 1;
  }

  .kp-ref-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 12px;
    border-radius: 2px;
    flex: 1;
    min-width: 110px;
  }

  .kp-3 { background:rgba(57,255,138,.12); border:1px solid rgba(57,255,138,.25); }
  .kp-5 { background:rgba(251,191,36,.12); border:1px solid rgba(251,191,36,.25); }
  .kp-7 { background:rgba(249,115,22,.12); border:1px solid rgba(249,115,22,.25); }
  .kp-9 { background:rgba(248,113,113,.12); border:1px solid rgba(248,113,113,.25); }

  .kp-num {
    font-family: var(--font-display);
    font-size: 18px;
    color: #fff;
    line-height: 1;
  }

  .kp-3 .kp-num { color: var(--accent-green); }
  .kp-5 .kp-num { color: var(--accent-yellow); }
  .kp-7 .kp-num { color: #f97316; }
  .kp-9 .kp-num { color: var(--accent-red); }

  .kp-loc {
    font-size: 10px;
    color: rgba(255,255,255,.5);
    line-height: 1.4;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .stream-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Make iframe visible once loaded (prevents black flash)
  document.querySelectorAll('.stream-embed iframe').forEach(iframe => {
    iframe.addEventListener('load', () => iframe.classList.add('loaded'));
    // Show after timeout so photo is visible if stream is offline
    setTimeout(() => iframe.classList.add('loaded'), 3000);
  });

  // Refresh NOAA oval map every 5 minutes
  const noaaOval = document.getElementById('noaa-oval');
  if (noaaOval) {
    setInterval(() => {
      const url = noaaOval.src.split('?')[0];
      noaaOval.src = `${url}?t=${Date.now()}`;
    }, 5 * 60 * 1000);
  }
</script>
