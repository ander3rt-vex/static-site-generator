---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Home"
  description="Aurora Watch — live Kp index, solar wind data, aurora forecasts, and live sky cameras."
  bgImage={`${base}images/home-bg.jpg`}
  activePage="home"
>

  <!-- ═══════════════════════════════════════════════════
       KP INFORMATION BAR  (matches #101431 bar in Figma)
  ═══════════════════════════════════════════════════ -->
  <div class="kp-bar">
    <div class="kp-bar-inner">

      <!-- Kp large display -->
      <div class="kp-main">
        <span class="kp-label-top">KP INDEX</span>
        <div class="kp-num-row">
          <span class="kp-num">3</span>
          <span class="kp-of">/9</span>
          <span class="badge badge-yellow" style="margin-left:14px">G1 — Minor</span>
        </div>
        <div class="kp-segments">
          {[1,2,3,4,5,6,7,8,9].map(n => (
            <div class={`kp-seg ${n<=3?'seg-on':''} ${n===5||n===6?'seg-warn':''} ${n>=7?'seg-danger':''}`}>
              <span>{n}</span>
            </div>
          ))}
        </div>
        <span class="kp-vis">Aurora visible: <strong>60°N+</strong> tonight</span>
      </div>

      <!-- Divider -->
      <div class="kp-divider"></div>

      <!-- Solar Wind -->
      <div class="kp-metric">
        <span class="kp-label-top">SOLAR WIND</span>
        <div class="kp-metric-val" style="color:#78c42a">420 <span class="kp-unit">km/s</span></div>
        <div class="kp-mini-bar">
          <div class="kp-mini-fill" style="width:52%; background:linear-gradient(90deg,#478F10,#78c42a)"></div>
        </div>
        <span class="kp-meta">Nominal: 350–450 km/s</span>
      </div>

      <div class="kp-divider"></div>

      <!-- IMF Bz -->
      <div class="kp-metric">
        <span class="kp-label-top">IMF Bz</span>
        <div class="kp-metric-val" style="color:#f07070">−4.2 <span class="kp-unit">nT</span></div>
        <div class="kp-bz-wrap">
          <div class="kp-bz-center"></div>
          <div class="kp-bz-fill"></div>
        </div>
        <span class="kp-meta" style="color:#f07070">▼ Southward — aurora favourable</span>
      </div>

      <div class="kp-divider"></div>

      <!-- NOAA G / S / R Scales -->
      <div class="kp-metric">
        <span class="kp-label-top">NOAA SCALES</span>
        <div class="noaa-chips">
          <div class="noaa-chip">
            <span class="nc-letter">G</span>
            <span class="badge badge-yellow">G1</span>
          </div>
          <div class="noaa-chip">
            <span class="nc-letter">S</span>
            <span class="badge badge-green">S0</span>
          </div>
          <div class="noaa-chip">
            <span class="nc-letter">R</span>
            <span class="badge badge-green">R0</span>
          </div>
        </div>
        <span class="kp-meta">Geomag · Radiation · Radio</span>
      </div>

      <div class="kp-divider"></div>

      <!-- Hemispheric Power -->
      <div class="kp-metric">
        <span class="kp-label-top">HEMISPHERIC POWER</span>
        <div class="kp-metric-val" style="color:#c977b7">42 <span class="kp-unit">GW</span></div>
        <div class="kp-mini-bar">
          <div class="kp-mini-fill" style="width:42%; background:linear-gradient(90deg,#5F37B4,#934284)"></div>
        </div>
        <span class="kp-meta">Northern hemisphere input</span>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════
       FEATURED LIVE CAMERAS  (2 cards, no border — Desktop-1)
  ═══════════════════════════════════════════════════ -->
  <section class="home-section">
    <h2 class="home-section-title">FEATURED CAMERAS</h2>

    <div class="featured-grid">

      <div class="featured-card">
        <div class="featured-embed">
          <img
            src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=800&q=80"
            alt="Aurora borealis — Lapland, Finland"
            class="feat-photo"
          />
          <iframe
            src="https://www.youtube.com/embed/live_stream?channel=UCrEfDv09Q2suoiSDt1hZIlg&autoplay=1&mute=1&modestbranding=1&rel=0"
            title="Aurora Borealis LIVE – Lapland Finland"
            frameborder="0"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
          <div class="feat-live-chip">
            <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
          </div>
        </div>
        <div class="feat-info">
          <span class="feat-loc">📍 Lapland, Finland · 68°N</span>
          <span class="feat-desc">Aurora Borealis LIVE! — 24/7 wilderness sky camera from remote Finnish Lapland</span>
          <a class="feat-link" href="https://www.youtube.com/channel/UCrEfDv09Q2suoiSDt1hZIlg" target="_blank" rel="noopener">Watch on YouTube →</a>
        </div>
      </div>

      <div class="featured-card">
        <div class="featured-embed">
          <img
            src="https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=800&q=80"
            alt="Aurora borealis — Fairbanks, Alaska"
            class="feat-photo"
          />
          <iframe
            src="https://www.youtube.com/embed/O52zDyxg5QI?autoplay=1&mute=1&modestbranding=1&rel=0&loop=1&playlist=O52zDyxg5QI"
            title="Fairbanks Aurora Cam — Explore.org"
            frameborder="0"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
          <div class="feat-live-chip">
            <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
          </div>
        </div>
        <div class="feat-info">
          <span class="feat-loc">📍 Fairbanks, Alaska · 64°N</span>
          <span class="feat-desc">Explore.org all-sky camera powered by UAF Geophysical Institute</span>
          <a class="feat-link" href="https://www.youtube.com/watch?v=O52zDyxg5QI" target="_blank" rel="noopener">Watch on YouTube →</a>
        </div>
      </div>

    </div>

    <a class="all-streams-btn" href={`${base}livestreams`}>
      View All Live Cameras →
    </a>
  </section>

  <!-- ═══════════════════════════════════════════════════
       AURORA OVAL MAP
  ═══════════════════════════════════════════════════ -->
  <section class="home-section">
    <h2 class="home-section-title">LIVE AURORA OVAL</h2>
    <div class="oval-row">
      <div class="oval-card">
        <img
          src="https://services.swpc.noaa.gov/images/animations/ovation/north/latest.jpg"
          alt="NOAA OVATION aurora oval — Northern Hemisphere"
          class="oval-img"
          id="noaa-oval"
          loading="lazy"
        />
        <div class="oval-meta">
          <span class="badge badge-purple">NOAA OVATION · 30-min forecast</span>
          <span class="oval-refresh">Auto-refreshes every 5 min</span>
        </div>
      </div>
      <div class="oval-legend">
        <h3 class="legend-title">HOW TO READ THE MAP</h3>
        <p class="legend-body">Brighter colours indicate higher aurora probability. The oval shifts poleward during quiet periods (Kp 1–3) and expands toward the equator as geomagnetic activity increases (Kp 5–9).</p>
        <div class="kp-vis-table">
          <div class="kvt-row">
            <span class="kvt-kp kp-col-3">Kp 3</span>
            <span class="kvt-loc">Iceland · Norway · Alaska · N. Canada</span>
          </div>
          <div class="kvt-row">
            <span class="kvt-kp kp-col-5">Kp 5</span>
            <span class="kvt-loc">Scotland · S. Norway · N. US border</span>
          </div>
          <div class="kvt-row">
            <span class="kvt-kp kp-col-7">Kp 7</span>
            <span class="kvt-loc">N. Germany · Central US states</span>
          </div>
          <div class="kvt-row">
            <span class="kvt-kp kp-col-9">Kp 9</span>
            <span class="kvt-loc">S. Europe · Southern US — major storm</span>
          </div>
        </div>
        <a class="oval-noaa-link" href="https://www.swpc.noaa.gov/communities/aurora-dashboard-experimental" target="_blank" rel="noopener">
          Open NOAA Dashboard →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       AURORA SCIENCE CARDS  (Figma palette colours)
  ═══════════════════════════════════════════════════ -->
  <section class="home-section">
    <h2 class="home-section-title">ABOUT THE AURORA</h2>

    <div class="science-grid">

      <div class="sci-card sci-purple">
        <div class="sci-accent"></div>
        <h3>What Causes Aurora?</h3>
        <p>The Sun emits a constant stream of charged particles — the solar wind. During solar flares and CMEs, these particles reach Earth's magnetosphere and spiral down magnetic field lines toward the poles, colliding with atmospheric oxygen and nitrogen to produce light.</p>
        <div class="sci-stat">
          <span class="sci-stat-num">100–300</span>
          <span class="sci-stat-label">km altitude where aurora forms</span>
        </div>
      </div>

      <div class="sci-card sci-mauve">
        <div class="sci-accent"></div>
        <h3>The Kp Index Explained</h3>
        <p>The Planetary K-index (Kp) measures global geomagnetic activity on a scale of 0–9, updated every 3 hours. Kp 5+ triggers the G-scale storm thresholds. The higher the Kp, the further from the poles aurora extends — a Kp 9 storm in May 2024 made aurora visible worldwide.</p>
        <div class="sci-stat">
          <span class="sci-stat-num">Kp 5</span>
          <span class="sci-stat-label">minimum for mid-latitude visibility</span>
        </div>
      </div>

      <div class="sci-card sci-green">
        <div class="sci-accent"></div>
        <h3>Why Bz Matters</h3>
        <p>The north-south component of the interplanetary magnetic field (IMF Bz) is the single most important real-time indicator. When Bz turns southward (negative), Earth's magnetic field opens up via reconnection, letting solar particles flood in. The stronger the negative Bz, the better the aurora.</p>
        <div class="sci-stat">
          <span class="sci-stat-num">−20 nT</span>
          <span class="sci-stat-label">Bz for a major aurora event</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       AURORA COLORS
  ═══════════════════════════════════════════════════ -->
  <section class="home-section">
    <h2 class="home-section-title">AURORA COLORS</h2>
    <div class="colors-strip">
      <div class="color-chip">
        <div class="cc-swatch" style="background:#39d877"></div>
        <strong>Green</strong>
        <span>Oxygen · 100–150 km</span>
        <span>Most common color</span>
      </div>
      <div class="color-chip">
        <div class="cc-swatch" style="background:#c44040"></div>
        <strong>Red</strong>
        <span>Oxygen · 200–300 km</span>
        <span>Rare high-altitude</span>
      </div>
      <div class="color-chip">
        <div class="cc-swatch" style="background:#4060c8"></div>
        <strong>Blue / Violet</strong>
        <span>Nitrogen · 80–100 km</span>
        <span>Lower edge fringe</span>
      </div>
      <div class="color-chip">
        <div class="cc-swatch" style="background:#934284"></div>
        <strong>Pink / Mauve</strong>
        <span>N₂ + O mix · 90 km</span>
        <span>Active substorms</span>
      </div>
      <div class="color-chip">
        <div class="cc-swatch" style="background:#5F37B4"></div>
        <strong>Purple</strong>
        <span>Nitrogen ions · 80 km</span>
        <span>Deep curtain base</span>
      </div>
      <div class="color-chip">
        <div class="cc-swatch" style="background:#b070e0"></div>
        <strong>STEVE</strong>
        <span>Sub-Auroral Ion Drift</span>
        <span>Mauve ribbon east–west</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       VIEWING TIPS
  ═══════════════════════════════════════════════════ -->
  <section class="home-section last-section">
    <h2 class="home-section-title">VIEWING TIPS</h2>
    <div class="tips-grid">
      <div class="tip-item">
        <span class="tip-icon" style="color:#478F10">🌑</span>
        <h4>Dark Sky</h4>
        <p>Travel at least 20 km from city lights. Even a small town can wash out a faint aurora display. Use <a href="https://www.lightpollutionmap.info/" target="_blank" rel="noopener">Light Pollution Map</a> to find dark sites.</p>
      </div>
      <div class="tip-item">
        <span class="tip-icon" style="color:#5F37B4">🕚</span>
        <h4>Best Hours</h4>
        <p>Geomagnetic substorms peak around local magnetic midnight — typically 10 pm to 2 am. Set an alert and get outside when Kp rises above your latitude threshold.</p>
      </div>
      <div class="tip-item">
        <span class="tip-icon" style="color:#934284">👁️</span>
        <h4>Dark-Adapt</h4>
        <p>Allow 20–30 minutes for your eyes to fully adjust to the dark. Avoid looking at your phone screen — use red-light mode if you must. The difference is dramatic.</p>
      </div>
      <div class="tip-item">
        <span class="tip-icon" style="color:#478F10">📷</span>
        <h4>Camera Trick</h4>
        <p>Take a 5-second photo even if you can't see anything. Camera sensors detect the green 557.7 nm wavelength better than the human eye — you might be surprised what's there.</p>
      </div>
      <div class="tip-item">
        <span class="tip-icon" style="color:#5F37B4">❄️</span>
        <h4>Face North</h4>
        <p>In the northern hemisphere, look toward magnetic north (slightly west of true north in most locations). The auroral arc rises from the northern horizon during moderate activity.</p>
      </div>
      <div class="tip-item">
        <span class="tip-icon" style="color:#934284">⚡</span>
        <h4>Watch Bz</h4>
        <p>Monitor the live Kp bar above. When Bz goes strongly negative (−10 nT or more) and holds there, get outside fast — that's your 15–60 minute warning from the DSCOVR satellite.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ═══════════════════════════════════
   KP BAR  (matches Figma #101431 bar)
═══════════════════════════════════ */
.kp-bar {
  position: relative;
  z-index: 15;
  background: rgba(16,20,49,.92);
  border-top:    1px solid var(--white-faint);
  border-bottom: 1px solid var(--white-faint);
  margin-top: 28px;
  backdrop-filter: blur(12px);
}

.kp-bar-inner {
  display: flex;
  align-items: center;
  gap: 0;
  padding: 20px 50px;
  overflow-x: auto;
}

.kp-divider {
  width: 1px;
  height: 60px;
  background: var(--white-faint);
  flex-shrink: 0;
  margin: 0 28px;
}

/* — Kp main — */
.kp-main {
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex-shrink: 0;
}

.kp-label-top {
  font-size: 9px;
  letter-spacing: .18em;
  color: rgba(255,255,255,.35);
  text-transform: uppercase;
  font-weight: 700;
}

.kp-num-row {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.kp-num {
  font-family: var(--font-display);
  font-size: 56px;
  line-height: 1;
  color: #78c42a;
  text-shadow: 0 0 24px rgba(71,143,16,.6);
}

.kp-of {
  font-family: var(--font-display);
  font-size: 24px;
  color: rgba(255,255,255,.3);
}

.kp-segments {
  display: flex;
  gap: 3px;
  margin-top: 2px;
}

.kp-seg {
  width: 18px;
  height: 10px;
  border-radius: 2px;
  background: rgba(255,255,255,.07);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.kp-seg span {
  font-size: 7px;
  color: rgba(255,255,255,.25);
  position: absolute;
  bottom: -13px;
}

.seg-on     { background: rgba(71,143,16,.8);  box-shadow: 0 0 6px rgba(71,143,16,.5); }
.seg-warn   { background: rgba(220,160,20,.25); }
.seg-danger { background: rgba(180,40,40,.25); }
.seg-on span { color: rgba(0,0,0,.5); }

.kp-vis {
  font-size: 11px;
  color: rgba(255,255,255,.45);
  margin-top: 16px;
}

.kp-vis strong { color: var(--white); }

/* — Metric column — */
.kp-metric {
  display: flex;
  flex-direction: column;
  gap: 5px;
  min-width: 140px;
}

.kp-metric-val {
  font-family: var(--font-display);
  font-size: 36px;
  line-height: 1;
}

.kp-unit { font-size: 16px; color: rgba(255,255,255,.35); }

.kp-mini-bar {
  height: 5px;
  background: rgba(255,255,255,.07);
  border-radius: 3px;
  overflow: hidden;
}

.kp-mini-fill {
  height: 100%;
  border-radius: 3px;
  box-shadow: 0 0 6px currentColor;
}

.kp-meta {
  font-size: 10px;
  color: rgba(255,255,255,.35);
  line-height: 1.35;
}

/* Bz gauge */
.kp-bz-wrap {
  position: relative;
  height: 5px;
  background: rgba(255,255,255,.07);
  border-radius: 3px;
  overflow: hidden;
}

.kp-bz-center {
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 1px;
  background: rgba(255,255,255,.2);
  z-index: 1;
}

.kp-bz-fill {
  position: absolute;
  top: 0; bottom: 0;
  right: 50%;
  width: 21%;
  background: linear-gradient(270deg, #f07070, rgba(240,112,112,.3));
  border-radius: 3px;
  box-shadow: 0 0 6px rgba(240,112,112,.5);
}

/* NOAA chips */
.noaa-chips { display: flex; gap: 10px; align-items: center; }
.noaa-chip  { display: flex; align-items: center; gap: 5px; }
.nc-letter  { font-family: var(--font-display); font-size: 18px; color: rgba(255,255,255,.4); }

/* ═══════════════════════════════════
   HOME SECTIONS
═══════════════════════════════════ */
.home-section {
  padding: 48px 50px 0;
}

.last-section {
  padding-bottom: 56px;
}

.home-section-title {
  font-family: var(--font-display);
  font-size: clamp(20px, 3vw, 36px);
  letter-spacing: .12em;
  color: var(--white);
  margin-bottom: 22px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--white-faint);
}

/* ═══════════════════════════════════
   FEATURED CAMERAS GRID  (2 col, no border — Desktop-1)
═══════════════════════════════════ */
.featured-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  margin-bottom: 20px;
}

.featured-card {
  background: var(--card);
  /* NO border — matches Desktop-1 video boxes */
  border-radius: 3px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow .3s;
}

.featured-card:hover {
  box-shadow: 0 0 28px rgba(95,55,180,.35);
}

/* 3:2 ratio (496:331 from Figma) */
.featured-embed {
  position: relative;
  padding-top: 66.73%;
  overflow: hidden;
  background: #06080e;
}

.feat-photo {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(.65) saturate(1.3);
  z-index: 1;
}

.featured-embed iframe {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  z-index: 2;
  border: none;
  opacity: 0;
  transition: opacity .7s;
}

.featured-embed iframe.loaded { opacity: 1; }

.feat-live-chip {
  position: absolute;
  top: 10px; right: 12px;
  z-index: 5;
}

.feat-info {
  padding: 12px 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.feat-loc  { font-size: 11px; color: rgba(255,255,255,.4); letter-spacing: .04em; }
.feat-desc { font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.45; }
.feat-link { font-size: 11px; color: #78c42a; text-decoration: none; margin-top: 3px; }
.feat-link:hover { text-decoration: underline; }

.all-streams-btn {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 22px;
  letter-spacing: .08em;
  color: var(--white);
  text-decoration: none;
  border: 2px solid var(--white-faint);
  padding: 10px 28px;
  border-radius: 3px;
  transition: background .2s, border-color .2s;
  margin-top: 4px;
}

.all-streams-btn:hover {
  background: rgba(95,55,180,.2);
  border-color: rgba(95,55,180,.7);
}

/* ═══════════════════════════════════
   AURORA OVAL
═══════════════════════════════════ */
.oval-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  align-items: start;
}

.oval-card {
  background: var(--card);
  border: 1px solid var(--white-faint);
  border-radius: 3px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.oval-img {
  width: 100%;
  display: block;
  object-fit: contain;
  background: #060810;
  filter: saturate(1.5) brightness(1.1);
  padding: 8px;
}

.oval-meta {
  padding: 10px 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--white-faint);
  gap: 10px;
  flex-wrap: wrap;
}

.oval-refresh { font-size: 10px; color: rgba(255,255,255,.3); }

.legend-title {
  font-family: var(--font-display);
  font-size: 20px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 12px;
}

.legend-body {
  font-size: 13px;
  color: rgba(255,255,255,.6);
  line-height: 1.7;
  margin-bottom: 20px;
}

.kp-vis-table { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }

.kvt-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 7px 0;
  border-bottom: 1px solid rgba(255,255,255,.05);
  font-size: 12px;
}

.kvt-kp {
  font-family: var(--font-display);
  font-size: 16px;
  min-width: 52px;
  padding: 2px 8px;
  border-radius: 2px;
  text-align: center;
}

.kp-col-3 { background: rgba(71,143,16,.2);  color: #78c42a; }
.kp-col-5 { background: rgba(220,160,20,.2); color: #f0c040; }
.kp-col-7 { background: rgba(180,80,20,.2);  color: #e08040; }
.kp-col-9 { background: rgba(180,40,40,.2);  color: #f07070; }

.kvt-loc { color: rgba(255,255,255,.55); }

.oval-noaa-link {
  font-family: var(--font-display);
  font-size: 20px;
  letter-spacing: .06em;
  color: var(--white);
  text-decoration: none;
  border: 1px solid var(--white-faint);
  padding: 8px 22px;
  border-radius: 3px;
  display: inline-block;
  transition: background .2s, border-color .2s;
}

.oval-noaa-link:hover {
  background: rgba(71,143,16,.2);
  border-color: rgba(71,143,16,.6);
}

/* ═══════════════════════════════════
   SCIENCE CARDS  (Figma palette colours)
═══════════════════════════════════ */
.science-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.sci-card {
  background: var(--card);
  border: 1px solid var(--white-faint);
  border-radius: 3px;
  padding: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.sci-accent { height: 4px; }
.sci-purple .sci-accent { background: linear-gradient(90deg, #5F37B4, #7a5abf); }
.sci-mauve  .sci-accent { background: linear-gradient(90deg, #934284, #b56098); }
.sci-green  .sci-accent { background: linear-gradient(90deg, #478F10, #6ac020); }

.sci-card h3 {
  font-family: var(--font-display);
  font-size: 20px;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--white);
  padding: 18px 20px 0;
}

.sci-card p {
  font-size: 12px;
  color: rgba(255,255,255,.6);
  line-height: 1.7;
  padding: 10px 20px 18px;
  flex: 1;
}

.sci-stat {
  display: flex;
  align-items: baseline;
  gap: 10px;
  padding: 12px 20px;
  border-top: 1px solid rgba(255,255,255,.06);
  background: rgba(0,0,0,.2);
}

.sci-stat-num   { font-family: var(--font-display); font-size: 24px; color: var(--white); }
.sci-stat-label { font-size: 11px; color: rgba(255,255,255,.4); }

.sci-purple .sci-stat-num { color: #9b7ef0; }
.sci-mauve  .sci-stat-num { color: #c977b7; }
.sci-green  .sci-stat-num { color: #78c42a; }

/* ═══════════════════════════════════
   AURORA COLORS STRIP
═══════════════════════════════════ */
.colors-strip {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12px;
}

.color-chip {
  background: var(--card);
  border: 1px solid var(--white-faint);
  border-radius: 3px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 4px;
  transition: border-color .3s, transform .2s;
}

.color-chip:hover {
  border-color: rgba(255,255,255,.5);
  transform: translateY(-2px);
}

.cc-swatch { height: 56px; width: 100%; }

.color-chip strong {
  font-family: var(--font-display);
  font-size: 16px;
  letter-spacing: .04em;
  color: var(--white);
  padding: 0 12px;
  text-transform: uppercase;
}

.color-chip span {
  font-size: 10px;
  color: rgba(255,255,255,.45);
  padding: 0 12px;
  line-height: 1.4;
}

.color-chip span:last-child { padding-bottom: 12px; }

/* ═══════════════════════════════════
   VIEWING TIPS
═══════════════════════════════════ */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.tip-item {
  background: var(--card);
  border: 1px solid var(--white-faint);
  border-radius: 3px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: border-color .3s;
}

.tip-item:hover { border-color: rgba(95,55,180,.5); }

.tip-icon { font-size: 28px; display: block; }

.tip-item h4 {
  font-family: var(--font-display);
  font-size: 18px;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--white);
}

.tip-item p {
  font-size: 12px;
  color: rgba(255,255,255,.6);
  line-height: 1.65;
  flex: 1;
}

.tip-item a { color: #78c42a; text-decoration: none; }
.tip-item a:hover { text-decoration: underline; }

/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media (max-width: 1100px) {
  .kp-bar-inner  { gap: 0; padding: 18px 20px; }
  .science-grid  { grid-template-columns: 1fr 1fr; }
  .colors-strip  { grid-template-columns: repeat(3, 1fr); }
  .tips-grid     { grid-template-columns: repeat(2, 1fr); }
  .oval-row      { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .kp-bar-inner  { flex-direction: column; align-items: flex-start; gap: 20px; }
  .kp-divider    { width: 100%; height: 1px; margin: 0; }
  .home-section  { padding: 32px 20px 0; }
  .featured-grid { grid-template-columns: 1fr; }
  .science-grid  { grid-template-columns: 1fr; }
  .colors-strip  { grid-template-columns: repeat(2, 1fr); }
  .tips-grid     { grid-template-columns: 1fr; }
}
</style>

<script>
  // Fade in iframes after load
  document.querySelectorAll('.featured-embed iframe').forEach(iframe => {
    iframe.addEventListener('load', () => iframe.classList.add('loaded'));
    setTimeout(() => iframe.classList.add('loaded'), 3500);
  });

  // Refresh NOAA oval every 5 min
  const oval = document.getElementById('noaa-oval') as HTMLImageElement | null;
  if (oval) {
    setInterval(() => {
      const src = oval.src.split('?')[0];
      oval.src = `${src}?t=${Date.now()}`;
    }, 300_000);
  }
</script>
