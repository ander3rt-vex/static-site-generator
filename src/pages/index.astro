---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const bgImage = `${base}images/aurora-bg.jpg`;
---

<Layout title="Livestreams" bgImage={bgImage}>

  <!-- ══════════════════════════════════════
       SPACE WEATHER DASHBOARD
       ══════════════════════════════════════ -->
  <section class="sw-dashboard">

    <!-- Kp Index — main metric -->
    <div class="sw-panel kp-panel">
      <div class="sw-label">PLANETARY Kp INDEX</div>
      <div class="kp-display">
        <div class="kp-big-num">3</div>
        <div class="kp-right">
          <div class="kp-bar-track">
            {[1,2,3,4,5,6,7,8,9].map(n => (
              <div class={`kp-seg ${n<=3?'seg-active':''} ${n===5||n===6?'seg-warn':''} ${n>=7?'seg-danger':''}`}>
                <span class="kp-seg-num">{n}</span>
              </div>
            ))}
          </div>
          <div class="kp-scale-labels">
            <span class="kpl green">QUIET</span>
            <span class="kpl yellow">MINOR</span>
            <span class="kpl red">MAJOR</span>
          </div>
          <div class="kp-status">
            <span class="badge badge-yellow">G1 — Minor Storm</span>
            <span class="kp-threshold">Aurora visible <strong>60°N+</strong></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Solar Wind Speed -->
    <div class="sw-panel wind-panel">
      <div class="sw-label">SOLAR WIND SPEED</div>
      <div class="metric-big">420<span class="metric-unit"> km/s</span></div>
      <div class="wind-bar-wrap">
        <div class="wind-bar">
          <div class="wind-fill" style="width:52%"></div>
          <div class="wind-marker slow" style="left:25%">300</div>
          <div class="wind-marker fast" style="left:62%">500</div>
        </div>
        <div class="wind-labels">
          <span>Slow (250)</span><span>Avg</span><span>Fast (800+)</span>
        </div>
      </div>
      <div class="sw-sub">Nominal: 350–450 km/s · Source: DSCOVR L1</div>
    </div>

    <!-- Bz Component — critical aurora driver -->
    <div class="sw-panel bz-panel">
      <div class="sw-label">IMF Bz COMPONENT</div>
      <div class="bz-display">
        <div class="bz-big" id="bz-value">−4.2 <span class="bz-unit">nT</span></div>
        <div class="bz-dir southward">▼ SOUTHWARD</div>
      </div>
      <div class="bz-gauge-wrap">
        <div class="bz-gauge">
          <div class="bz-center-line"></div>
          <div class="bz-fill south" style="width:21%"></div>
        </div>
        <div class="bz-gauge-labels">
          <span class="bz-north">+20 North ↑</span>
          <span class="bz-zero">0</span>
          <span class="bz-south">↓ South −20</span>
        </div>
      </div>
      <div class="sw-sub bz-tip">Southward Bz drives aurora — stronger negative = better chance</div>
    </div>

    <!-- Density + Hemispheric Power -->
    <div class="sw-panel extra-panel">
      <div class="sw-label">SPACE WEATHER STATUS</div>
      <div class="extra-metrics">
        <div class="extra-row">
          <span class="extra-name">Proton Density</span>
          <div class="mini-bar-wrap">
            <div class="mini-bar"><div class="mini-fill density-fill" style="width:31%"></div></div>
          </div>
          <span class="extra-val">6.1 <span class="extra-u">p/cc</span></span>
        </div>
        <div class="extra-row">
          <span class="extra-name">Hemispheric Pwr</span>
          <div class="mini-bar-wrap">
            <div class="mini-bar"><div class="mini-fill power-fill" style="width:42%"></div></div>
          </div>
          <span class="extra-val">42 <span class="extra-u">GW</span></span>
        </div>
        <div class="extra-row">
          <span class="extra-name">Radio Flux (F10.7)</span>
          <div class="mini-bar-wrap">
            <div class="mini-bar"><div class="mini-fill flux-fill" style="width:67%"></div></div>
          </div>
          <span class="extra-val">148 <span class="extra-u">sfu</span></span>
        </div>
        <div class="extra-row">
          <span class="extra-name">Total Field (Bt)</span>
          <div class="mini-bar-wrap">
            <div class="mini-bar"><div class="mini-fill bt-fill" style="width:42%"></div></div>
          </div>
          <span class="extra-val">8.4 <span class="extra-u">nT</span></span>
        </div>
      </div>
      <div class="noaa-scale-row">
        <div class="noaa-chip"><span class="noaa-letter">G</span><span class="badge badge-yellow">G1</span></div>
        <div class="noaa-chip"><span class="noaa-letter">S</span><span class="badge badge-green">S0</span></div>
        <div class="noaa-chip"><span class="noaa-letter">R</span><span class="badge badge-green">R0</span></div>
        <span class="noaa-src">NOAA SWPC · updates every 60s</span>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════
       LIVE STREAM GRID  (2 × 2, Figma layout)
       ══════════════════════════════════════ -->
  <h2 class="streams-heading">
    <span class="badge badge-green"><span class="pulse-dot"></span>LIVE CAMERAS</span>
  </h2>

  <section class="stream-grid">

    <!-- Card 1 — Aurora Borealis LIVE! · Lapland, Finland -->
    <div class="stream-card">
      <div class="stream-embed">
        <img src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=800&q=80"
             alt="Aurora borealis Lapland" class="card-photo" loading="lazy" />
        <iframe
          src="https://www.youtube.com/embed/live_stream?channel=UCrEfDv09Q2suoiSDt1hZIlg&autoplay=1&mute=1&modestbranding=1&rel=0"
          title="Aurora Borealis LIVE – Lapland Finland"
          frameborder="0" allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen loading="lazy"
        ></iframe>
        <div class="embed-badge"><span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span></div>
      </div>
      <div class="card-footer">
        <div class="card-loc">📍 Lapland, Finland · 68°N</div>
        <div class="card-desc">Aurora Borealis LIVE! — 24/7 remote wilderness sky camera from Finnish Lapland</div>
        <a class="card-link" href="https://www.youtube.com/channel/UCrEfDv09Q2suoiSDt1hZIlg" target="_blank" rel="noopener">Open on YouTube →</a>
      </div>
    </div>

    <!-- Card 2 — Explore.org Fairbanks Aurora Cam -->
    <div class="stream-card">
      <div class="stream-embed">
        <img src="https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=800&q=80"
             alt="Aurora borealis Alaska" class="card-photo" loading="lazy" />
        <iframe
          src="https://www.youtube.com/embed/O52zDyxg5QI?autoplay=1&mute=1&modestbranding=1&rel=0&loop=1&playlist=O52zDyxg5QI"
          title="Fairbanks Aurora Camera – Explore.org"
          frameborder="0" allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen loading="lazy"
        ></iframe>
        <div class="embed-badge"><span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span></div>
      </div>
      <div class="card-footer">
        <div class="card-loc">📍 Fairbanks, Alaska · 64°N</div>
        <div class="card-desc">Explore.org sky camera powered by UAF Geophysical Institute · Refreshes every 10 min</div>
        <a class="card-link" href="https://www.youtube.com/watch?v=O52zDyxg5QI" target="_blank" rel="noopener">Open on YouTube →</a>
      </div>
    </div>

    <!-- Card 3 — North Dakota Dual Aurora Cameras -->
    <div class="stream-card">
      <div class="stream-embed">
        <img src="https://images.unsplash.com/photo-1566132127697-4524fea60007?auto=format&fit=crop&w=800&q=80"
             alt="Aurora borealis night sky" class="card-photo" loading="lazy" />
        <iframe
          src="https://www.youtube.com/embed/live_stream?channel=UC7pBM_HJbGO7IlYIAsFcKAg&autoplay=1&mute=1&modestbranding=1&rel=0"
          title="North Dakota Dual Aurora Cameras"
          frameborder="0" allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen loading="lazy"
        ></iframe>
        <div class="embed-badge"><span class="badge badge-cyan">ALL-SKY CAM</span></div>
      </div>
      <div class="card-footer">
        <div class="card-loc">📍 Inkster, North Dakota · 48°N</div>
        <div class="card-desc">NoDDAC citizen science — dual north-facing cameras at Martens Observatory</div>
        <a class="card-link" href="https://www.youtube.com/channel/UC7pBM_HJbGO7IlYIAsFcKAg" target="_blank" rel="noopener">Open on YouTube →</a>
      </div>
    </div>

    <!-- Card 4 — NOAA Live Aurora Oval -->
    <div class="stream-card">
      <div class="stream-embed noaa-embed">
        <img
          src="https://services.swpc.noaa.gov/images/animations/ovation/north/latest.jpg"
          alt="NOAA OVATION aurora oval forecast – Northern Hemisphere"
          class="card-photo noaa-map" loading="lazy" id="noaa-oval"
        />
        <div class="noaa-overlay">
          <div class="no-row">
            <span class="no-lbl">Kp Index</span>
            <div class="no-kpbar">{[1,2,3,4,5,6,7,8,9].map(n=>(
              <div class={`no-seg ${n<=3?'nos-active':n<=5?'nos-warn':n<=7?'nos-hi':'nos-ext'}`}></div>
            ))}</div>
            <span class="no-val">3</span>
          </div>
          <div class="no-row">
            <span class="no-lbl">Bz</span>
            <span class="no-val no-neg">−4.2 nT ↓</span>
          </div>
          <div class="no-row">
            <span class="no-lbl">G-Scale</span>
            <span class="badge badge-yellow">G1</span>
          </div>
        </div>
        <div class="embed-badge"><span class="badge badge-purple">NOAA OVATION</span></div>
      </div>
      <div class="card-footer">
        <div class="card-loc">🛰️ NOAA DSCOVR · L1 Lagrange Point</div>
        <div class="card-desc">Real-time aurora oval probability map · Auto-refreshes every 5 min</div>
        <a class="card-link" href="https://www.swpc.noaa.gov/communities/aurora-dashboard-experimental" target="_blank" rel="noopener">NOAA Dashboard →</a>
      </div>
    </div>

  </section>

  <!-- ══════════════════════════════════════
       KP VISIBILITY REFERENCE
       ══════════════════════════════════════ -->
  <section class="visibility-bar">
    <span class="vis-label">TONIGHT'S FORECAST</span>
    <div class="vis-items">
      <div class="vis-item v-kp3">
        <span class="vis-kp">Kp 3–4</span>
        <span class="vis-loc">Iceland · Norway · Alaska · Canada</span>
      </div>
      <div class="vis-divider">→</div>
      <div class="vis-item v-kp5">
        <span class="vis-kp">Kp 5</span>
        <span class="vis-loc">Scotland · Southern Norway · N. US border</span>
      </div>
      <div class="vis-divider">→</div>
      <div class="vis-item v-kp7">
        <span class="vis-kp">Kp 7</span>
        <span class="vis-loc">N. Germany · Mid US states</span>
      </div>
      <div class="vis-divider">→</div>
      <div class="vis-item v-kp9">
        <span class="vis-kp">Kp 9</span>
        <span class="vis-loc">S. Europe · Southern US — Rare major storm</span>
      </div>
    </div>
    <div class="vis-current">
      <span class="badge badge-yellow">Current: Kp 3 → 60°N+ visible</span>
    </div>
  </section>

</Layout>

<style>
  /* ═══════════════════════════════════
     SPACE WEATHER DASHBOARD
  ═══════════════════════════════════ */
  .sw-dashboard {
    display: grid;
    grid-template-columns: 2fr 1.4fr 1.4fr 1.4fr;
    gap: 14px;
    margin-bottom: 28px;
  }

  .sw-panel {
    background: rgba(16,20,49,.82);
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 4px;
    padding: 18px 20px;
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sw-label {
    font-size: 9px;
    letter-spacing: .18em;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    font-weight: 700;
  }

  .sw-sub {
    font-size: 10px;
    color: rgba(255,255,255,.35);
    margin-top: auto;
    line-height: 1.45;
  }

  /* — Kp Panel — */
  .kp-panel { border-left: 3px solid var(--accent-green); }

  .kp-display {
    display: flex;
    align-items: center;
    gap: 18px;
    flex: 1;
  }

  .kp-big-num {
    font-family: var(--font-display);
    font-size: 72px;
    line-height: 1;
    color: var(--accent-green);
    text-shadow: 0 0 30px rgba(57,255,138,.6);
    flex-shrink: 0;
  }

  .kp-right { display: flex; flex-direction: column; gap: 8px; flex: 1; }

  .kp-bar-track {
    display: flex;
    gap: 3px;
    align-items: flex-end;
  }

  .kp-seg {
    flex: 1;
    height: 28px;
    background: rgba(255,255,255,.07);
    border-radius: 2px;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 3px;
  }

  .seg-active  { background: rgba(57,255,138,.75); box-shadow: 0 0 8px rgba(57,255,138,.4); }
  .seg-warn    { background: rgba(251,191,36,.2); }
  .seg-danger  { background: rgba(248,113,113,.2); }

  .kp-seg-num { font-size: 8px; color: rgba(255,255,255,.5); }
  .seg-active .kp-seg-num { color: rgba(0,0,0,.7); }

  .kp-scale-labels {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    letter-spacing: .06em;
    font-weight: 700;
  }

  .kpl { text-transform: uppercase; }
  .kpl.green  { color: var(--accent-green); }
  .kpl.yellow { color: var(--accent-yellow); }
  .kpl.red    { color: var(--accent-red); }

  .kp-status {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .kp-threshold { font-size: 11px; color: rgba(255,255,255,.5); }
  .kp-threshold strong { color: #fff; }

  /* — Solar Wind Panel — */
  .wind-panel { border-left: 3px solid var(--accent-cyan); }

  .metric-big {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 1;
    color: var(--accent-cyan);
    text-shadow: 0 0 24px rgba(34,211,238,.5);
  }
  .metric-unit { font-size: 20px; color: rgba(255,255,255,.45); }

  .wind-bar-wrap { position: relative; }

  .wind-bar {
    height: 10px;
    background: rgba(255,255,255,.08);
    border-radius: 5px;
    overflow: visible;
    position: relative;
    margin-bottom: 18px;
  }

  .wind-fill {
    height: 100%;
    border-radius: 5px;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-green));
    box-shadow: 0 0 10px rgba(34,211,238,.5);
  }

  .wind-marker {
    position: absolute;
    top: 14px;
    font-size: 8px;
    color: rgba(255,255,255,.35);
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .wind-labels {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    color: rgba(255,255,255,.25);
  }

  /* — Bz Panel — */
  .bz-panel { border-left: 3px solid var(--accent-red); }

  .bz-display {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .bz-big {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 1;
    color: var(--accent-red);
    text-shadow: 0 0 24px rgba(248,113,113,.5);
  }
  .bz-unit { font-size: 20px; color: rgba(255,255,255,.45); }

  .bz-dir {
    font-size: 11px;
    letter-spacing: .1em;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
    align-self: center;
  }
  .southward {
    background: rgba(248,113,113,.15);
    color: var(--accent-red);
    border: 1px solid rgba(248,113,113,.4);
    animation: bz-pulse 2s ease-in-out infinite;
  }

  @keyframes bz-pulse {
    0%,100% { box-shadow: none; }
    50% { box-shadow: 0 0 10px rgba(248,113,113,.4); }
  }

  .bz-gauge-wrap { position: relative; }

  .bz-gauge {
    height: 10px;
    background: rgba(255,255,255,.08);
    border-radius: 5px;
    overflow: hidden;
    position: relative;
    margin-bottom: 4px;
  }

  .bz-center-line {
    position: absolute;
    left: 50%; top: 0; bottom: 0;
    width: 1px;
    background: rgba(255,255,255,.25);
  }

  .bz-fill {
    position: absolute;
    top: 0; bottom: 0;
    border-radius: 5px;
  }

  .bz-fill.south {
    right: 50%;
    background: linear-gradient(270deg, var(--accent-red), rgba(248,113,113,.3));
    box-shadow: 0 0 8px rgba(248,113,113,.5);
  }

  .bz-gauge-labels {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
  }

  .bz-north  { color: var(--accent-cyan); }
  .bz-zero   { color: rgba(255,255,255,.3); text-align: center; }
  .bz-south  { color: var(--accent-red); }
  .bz-tip    { font-style: italic; }

  /* — Extra Metrics Panel — */
  .extra-panel { border-left: 3px solid var(--accent-purple); }

  .extra-metrics { display: flex; flex-direction: column; gap: 8px; flex: 1; }

  .extra-row {
    display: grid;
    grid-template-columns: 105px 1fr 56px;
    align-items: center;
    gap: 8px;
  }

  .extra-name { font-size: 10px; color: rgba(255,255,255,.5); }
  .extra-val  { font-size: 12px; color: #fff; font-weight: 600; text-align: right; }
  .extra-u    { font-size: 9px; color: rgba(255,255,255,.4); }

  .mini-bar-wrap {}
  .mini-bar {
    height: 5px;
    background: rgba(255,255,255,.07);
    border-radius: 3px;
    overflow: hidden;
  }
  .mini-fill { height: 100%; border-radius: 3px; }
  .density-fill { background: linear-gradient(90deg, var(--accent-purple), var(--accent-magenta)); }
  .power-fill   { background: linear-gradient(90deg, var(--accent-green), var(--accent-cyan)); }
  .flux-fill    { background: linear-gradient(90deg, var(--accent-yellow), #f97316); }
  .bt-fill      { background: linear-gradient(90deg, var(--accent-cyan), var(--accent-purple)); }

  .noaa-scale-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,.07);
    margin-top: auto;
  }

  .noaa-chip { display: flex; align-items: center; gap: 5px; }
  .noaa-letter { font-family: var(--font-display); font-size: 16px; color: rgba(255,255,255,.45); }
  .noaa-src { font-size: 9px; color: rgba(255,255,255,.25); margin-left: auto; }

  /* ═══════════════════════════════════
     STREAMS HEADING
  ═══════════════════════════════════ */
  .streams-heading {
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* ═══════════════════════════════════
     STREAM GRID — 2×2 (Figma layout)
  ═══════════════════════════════════ */
  .stream-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 20px;
  }

  .stream-card {
    background: #101431;
    border: 3px solid #ffffff;
    border-radius: 3px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color .3s, box-shadow .3s;
  }

  .stream-card:hover {
    border-color: rgba(168,85,247,.9);
    box-shadow: 0 0 32px rgba(120,80,255,.25);
  }

  /* 3:2 ratio (496:331 from Figma) */
  .stream-embed {
    position: relative;
    width: 100%;
    padding-top: 66.73%;
    overflow: hidden;
    background: #060810;
  }

  .card-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(.7) saturate(1.3);
    z-index: 1;
  }

  .noaa-map {
    object-fit: contain;
    background: #060810;
    filter: saturate(1.5) brightness(1.1);
    padding: 8px;
  }

  .stream-embed iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    z-index: 2; border: none;
    opacity: 0; transition: opacity .6s;
  }

  .stream-embed iframe.loaded { opacity: 1; }

  .embed-badge {
    position: absolute;
    top: 10px; right: 12px;
    z-index: 5;
  }

  /* NOAA data overlay */
  .noaa-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 4;
    background: linear-gradient(transparent, rgba(8,10,24,.95));
    padding: 28px 14px 12px;
    display: flex; flex-direction: column; gap: 5px;
  }

  .no-row { display: flex; align-items: center; gap: 8px; font-size: 11px; }
  .no-lbl { color: rgba(255,255,255,.5); width: 70px; flex-shrink: 0; }
  .no-val { color: #fff; font-weight: 600; }
  .no-neg { color: var(--accent-red); }

  .no-kpbar { display: flex; gap: 2px; flex: 1; height: 6px; }
  .no-seg   { flex: 1; height: 6px; border-radius: 1px; background: rgba(255,255,255,.07); }
  .nos-active { background: rgba(57,255,138,.7); }
  .nos-warn   { background: rgba(251,191,36,.25); }
  .nos-hi     { background: rgba(249,115,22,.25); }
  .nos-ext    { background: rgba(248,113,113,.25); }

  /* Card footer */
  .card-footer {
    padding: 12px 16px 14px;
    display: flex; flex-direction: column; gap: 4px;
    background: #101431;
  }

  .card-loc  { font-size: 11px; color: rgba(255,255,255,.45); letter-spacing: .04em; }
  .card-desc { font-size: 12px; color: rgba(255,255,255,.72); line-height: 1.45; }
  .card-link {
    font-size: 11px; color: var(--accent-cyan);
    text-decoration: none; margin-top: 3px;
    letter-spacing: .04em; display: inline-block;
  }
