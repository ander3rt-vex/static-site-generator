<script>
  document.querySelectorAll('.stream-embed iframe').forEach(iframe => {
    iframe.addEventListener('load', () => iframe.classList.add('loaded'));
    setTimeout(() => iframe.classList.add('loaded'), 3500);
  });

  const noaaOval = document.getElementById('noaa-oval') as HTMLImageElement | null;
  if (noaaOval) {
    setInterval(() => {
      const base = noaaOval.src.split('?')[0];
      noaaOval.src = `${base}?t=${Date.now()}`;
    }, 5 * 60 * 1000);
  }
</script>
