---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const bgImage = `${base}images/aurora-about-bg.jpg`;
---

<Layout
  title="About"
  description="Learn about aurora borealis — what causes the northern lights, how to see them, and how space weather is monitored."
  bgImage={bgImage}
>
  <!-- ── Page Hero ── -->
  <div class="about-hero">
    <h1 class="hero-heading">WHAT IS THE AURORA?</h1>
    <p class="hero-sub">
      The aurora borealis — northern lights — is caused by charged solar particles colliding
      with Earth's atmosphere. Energetic electrons and protons spiral along magnetic field lines
      into the polar regions, exciting atmospheric gases into brilliant ribbons of green, purple, and red.
    </p>
  </div>

  <!-- ── Photo Strip — free-use aurora images ── -->
  <section class="photo-strip">
    <div class="photo-item">
      <img
        src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=600&q=80"
        alt="Green aurora borealis over a dark landscape"
        loading="lazy"
      />
      <div class="photo-caption">Northern lights reflected in still water</div>
    </div>
    <div class="photo-item">
      <img
        src="https://images.unsplash.com/photo-1566132127697-4524fea60007?auto=format&fit=crop&w=600&q=80"
        alt="Aurora borealis over snowy mountains"
        loading="lazy"
      />
      <div class="photo-caption">Green aurora over snow-capped peaks</div>
    </div>
    <div class="photo-item">
      <img
        src="https://images.unsplash.com/photo-1551244072-5d12893278bc?auto=format&fit=crop&w=600&q=80"
        alt="Purple and green aurora borealis"
        loading="lazy"
      />
      <div class="photo-caption">Purple and green auroral curtains</div>
    </div>
    <div class="photo-item">
      <img
        src="https://images.unsplash.com/photo-1494243762909-b498c7e7b548?auto=format&fit=crop&w=600&q=80"
        alt="Aurora borealis over a road at night"
        loading="lazy"
      />
      <div class="photo-caption">Aurora over a remote northern road</div>
    </div>
  </section>
  <p class="photo-credit">Photos: <a href="https://unsplash.com/s/photos/aurora-borealis" target="_blank" rel="noopener">Unsplash</a> (free to use, no attribution required)</p>

  <!-- ── How Auroras Form ── -->
  <section class="content-section">
    <h2 class="section-heading">HOW AURORAS FORM</h2>
    <div class="science-grid">
      <div class="science-card">
        <div class="sci-num">01</div>
        <div class="sci-icon">☀️</div>
        <h3>Solar Wind</h3>
        <p>The Sun continuously emits a stream of charged particles. During solar flares and CMEs, billions of tons of magnetized plasma are hurled toward Earth at millions of km/h.</p>
      </div>
      <div class="science-card">
        <div class="sci-num">02</div>
        <div class="sci-icon">🌍</div>
        <h3>Magnetosphere</h3>
        <p>Earth's magnetic field deflects most solar wind. When the Bz component turns southward, magnetic reconnection opens a channel funneling particles toward the poles.</p>
      </div>
      <div class="science-card">
        <div class="sci-num">03</div>
        <div class="sci-icon">💡</div>
        <h3>Atmospheric Glow</h3>
        <p>Particles collide with atmospheric gases at 100–300 km altitude. Oxygen emits green (120 km) and red (above 200 km). Nitrogen produces blue and purple hues.</p>
      </div>
      <div class="science-card">
        <div class="sci-num">04</div>
        <div class="sci-icon">🌐</div>
        <h3>Auroral Oval</h3>
        <p>Aurora concentrates in a ring around the geomagnetic poles — the auroral oval — sitting around 65–70°N during quiet periods, expanding to 40°N during Kp 9 storms.</p>
      </div>
    </div>
  </section>

  <!-- ── NOAA Geomagnetic Storm Scale ── -->
  <section class="content-section">
    <h2 class="section-heading">NOAA GEOMAGNETIC SCALE (G SCALE)</h2>
    <div class="g-scale-table">
      <div class="g-row g-header">
        <span>Scale</span><span>Kp</span><span>Aurora Visibility</span><span>Effects</span>
      </div>
      <div class="g-row g1-row">
        <span class="g-badge g1">G1</span>
        <span>Kp 5</span>
        <span>65°N+ (Iceland, Norway, Alaska)</span>
        <span>Minor power fluctuations, satellite drag</span>
      </div>
      <div class="g-row g2-row">
        <span class="g-badge g2">G2</span>
        <span>Kp 6</span>
        <span>60°N+ (Scotland, S. Norway, S. Canada)</span>
        <span>High-latitude power systems, transformer damage possible</span>
      </div>
      <div class="g-row g3-row">
        <span class="g-badge g3">G3</span>
        <span>Kp 7</span>
        <span>50°N+ (N. Germany, N. US states)</span>
        <span>Voltage problems, GPS errors, satellite orientation issues</span>
      </div>
      <div class="g-row g4-row">
        <span class="g-badge g4">G4</span>
        <span>Kp 8</span>
        <span>45°N+ (Central Europe, Central US)</span>
        <span>Widespread power outages, pipeline corrosion</span>
      </div>
      <div class="g-row g5-row">
        <span class="g-badge g5">G5</span>
        <span>Kp 9</span>
        <span>40°N+ (S. Europe, S. US — Carrington-class)</span>
        <span>Extreme: may 2024 aurora visible from Florida &amp; Texas</span>
      </div>
    </div>
  </section>

  <!-- ── Best Viewing Locations (with photos) ── -->
  <section class="content-section">
    <h2 class="section-heading">BEST PLACES TO SEE AURORAS</h2>
    <div class="places-grid">

      <div class="place-card">
        <div class="place-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=500&q=80"
            alt="Northern lights in Norway"
            loading="lazy"
          />
        </div>
        <div class="place-body">
          <div class="place-flag-name">
            <span class="flag">🇳🇴</span>
            <h3>Tromsø, Norway</h3>
          </div>
          <div class="place-lat">69.6°N · Oct – Mar</div>
          <p>Inside the auroral oval most of the year. Dark polar nights Nov–Feb. The world's "aurora capital."</p>
          <span class="badge badge-green">BEST VIEWING</span>
        </div>
      </div>

      <div class="place-card">
        <div class="place-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1494243762909-b498c7e7b548?auto=format&fit=crop&w=500&q=80"
            alt="Northern lights in Iceland"
            loading="lazy"
          />
        </div>
        <div class="place-body">
          <div class="place-flag-name">
            <span class="flag">🇮🇸</span>
            <h3>Iceland</h3>
          </div>
          <div class="place-lat">64–66°N · Sep – Apr</div>
          <p>Vast dark landscapes with minimal light pollution. Kp 3 is enough. Reykjavik has dark sky access nearby.</p>
          <span class="badge badge-green">HIGHLY RECOMMENDED</span>
        </div>
      </div>

      <div class="place-card">
        <div class="place-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1566132127697-4524fea60007?auto=format&fit=crop&w=500&q=80"
            alt="Northern lights over Finnish Lapland"
            loading="lazy"
          />
        </div>
        <div class="place-body">
          <div class="place-flag-name">
            <span class="flag">🇫🇮</span>
            <h3>Finnish Lapland</h3>
          </div>
          <div class="place-lat">68–70°N · Nov – Mar</div>
          <p>~200 aurora nights per year. Glass-roofed aurora cabins for lying-in-bed viewing.</p>
          <span class="badge badge-green">HIGHLY RECOMMENDED</span>
        </div>
      </div>

      <div class="place-card">
        <div class="place-photo-wrap">
          <img
            src="https://images.unsplash.com/photo-1551244072-5d12893278bc?auto=format&fit=crop&w=500&q=80"
            alt="Northern lights in Alaska"
            loading="lazy"
          />
        </div>
        <div class="place-body">
          <div class="place-flag-name">
            <span class="flag">🇺🇸</span>
            <h3>Fairbanks, Alaska</h3>
          </div>
          <div class="place-lat">64.8°N · Oct – Mar</div>
          <p>Home of Poker Flat Research Range. Clear, cold nights under the auroral oval with excellent UAF camera coverage.</p>
          <span class="badge badge-yellow">GREAT OPTION</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Photography Guide ── -->
  <section class="content-section">
    <h2 class="section-heading">AURORA PHOTOGRAPHY SETTINGS</h2>
    <div class="photo-guide-grid">
      <div class="setting-card">
        <div class="setting-icon">📷</div>
        <div class="setting-label">ISO</div>
        <div class="setting-value">800 – 3200</div>
        <div class="setting-tip">Start at 1600, adjust for brightness</div>
      </div>
      <div class="setting-card">
        <div class="setting-icon">🔭</div>
        <div class="setting-label">Aperture</div>
        <div class="setting-value">f/1.8 – f/2.8</div>
        <div class="setting-tip">As wide as your lens allows</div>
      </div>
      <div class="setting-card">
        <div class="setting-icon">⏱️</div>
        <div class="setting-label">Shutter</div>
        <div class="setting-value">5 – 25 sec</div>
        <div class="setting-tip">Faster for active dancing aurora</div>
      </div>
      <div class="setting-card">
        <div class="setting-icon">🎯</div>
        <div class="setting-label">Focus</div>
        <div class="setting-value">Manual ∞</div>
        <div class="setting-tip">Autofocus fails in the dark</div>
      </div>
      <div class="setting-card">
        <div class="setting-icon">🌡️</div>
        <div class="setting-label">White Balance</div>
        <div class="setting-value">3500 – 4500 K</div>
        <div class="setting-tip">Or shoot RAW and set in post</div>
      </div>
      <div class="setting-card">
        <div class="setting-icon">💾</div>
        <div class="setting-label">Format</div>
        <div class="setting-value">RAW</div>
        <div class="setting-tip">Essential for post-processing flexibility</div>
      </div>
    </div>
  </section>

  <!-- ── Resources ── -->
  <section class="content-section">
    <h2 class="section-heading">MONITORING RESOURCES</h2>
    <div class="resources-grid">
      <a class="resource-link" href="https://www.swpc.noaa.gov/communities/aurora-dashboard-experimental" target="_blank" rel="noopener">
        <span class="resource-badge">NOAA</span>
        <div>
          <div class="resource-name">NOAA Aurora Dashboard</div>
          <div class="resource-desc">Official US space weather forecasting — Kp index, aurora oval, solar wind</div>
        </div>
        <span class="resource-arrow">→</span>
      </a>
      <a class="resource-link" href="https://services.swpc.noaa.gov/images/animations/ovation/north/latest.jpg" target="_blank" rel="noopener">
        <span class="resource-badge">OVT</span>
        <div>
          <div class="resource-name">OVATION Aurora Model</div>
          <div class="resource-desc">Real-time 30-minute aurora oval probability forecast map</div>
        </div>
        <span class="resource-arrow">→</span>
      </a>
      <a class="resource-link" href="https://www.gi.alaska.edu/monitors/aurora-forecast" target="_blank" rel="noopener">
        <span class="resource-badge">UAF</span>
        <div>
          <div class="resource-name">UAF Aurora Forecast</div>
          <div class="resource-desc">University of Alaska Fairbanks — all-sky cameras and regional forecasts</div>
        </div>
        <span class="resource-arrow">→</span>
      </a>
      <a class="resource-link" href="https://aurorasaurus.org/" target="_blank" rel="noopener">
        <span class="resource-badge">A★</span>
        <div>
          <div class="resource-name">Aurorasaurus</div>
          <div class="resource-desc">Citizen science platform — real-time community aurora sightings and alerts</div>
        </div>
        <span class="resource-arrow">→</span>
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .about-hero {
    margin-bottom: 36px;
    max-width: 780px;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 72px);
    letter-spacing: .05em;
    color: #fff;
    margin-bottom: 16px;
    text-shadow: 0 2px 30px rgba(0,0,0,.7);
    line-height: 1.05;
  }

  .hero-sub {
    font-size: 15px;
    line-height: 1.8;
    color: rgba(255,255,255,.72);
    max-width: 680px;
  }

  /* ── Photo strip ── */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 6px;
  }

  .photo-item {
    position: relative;
    border-radius: 3px;
    overflow: hidden;
    aspect-ratio: 4/3;
    border: 2px solid rgba(255,255,255,.18);
    transition: border-color .3s, transform .2s;
  }

  .photo-item:hover {
    border-color: rgba(168,85,247,.7);
    transform: scale(1.02);
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.85) saturate(1.2);
    transition: filter .3s;
  }

  .photo-item:hover img { filter: brightness(1) saturate(1.4); }

  .photo-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(6,8,20,.85));
    padding: 18px 8px 7px;
    font-size: 10px;
    color: rgba(255,255,255,.7);
    line-height: 1.3;
  }

  .photo-credit {
    font-size: 11px;
    color: rgba(255,255,255,.3);
    margin-bottom: 48px;
  }

  .photo-credit a { color: var(--accent-green); text-decoration: none; }
  .photo-credit a:hover { text-decoration: underline; }

  /* ── Content sections ── */
  .content-section { margin-bottom: 56px; }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 30px);
    letter-spacing: .1em;
    color: #fff;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255,255,255,.12);
  }

  /* ── Science grid ── */
  .science-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .science-card {
    background: rgba(16,20,49,.8);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 3px;
    padding: 20px;
    backdrop-filter: blur(6px);
    position: relative;
    overflow: hidden;
  }

  .sci-num {
    font-family: var(--font-display);
    font-size: 52px;
    color: rgba(255,255,255,.05);
    position: absolute;
    top: 6px; right: 12px;
    line-height: 1;
  }

  .sci-icon { font-size: 26px; margin-bottom: 10px; display: block; }

  .science-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 8px;
  }

  .science-card p {
    font-size: 12px;
    color: rgba(255,255,255,.6);
    line-height: 1.65;
  }

  /* ── G-scale table ── */
  .g-scale-table {
    background: rgba(16,20,49,.8);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 3px;
    overflow: hidden;
    backdrop-filter: blur(6px);
  }

  .g-row {
    display: grid;
    grid-template-columns: 60px 60px 1fr 1fr;
    gap: 16px;
    align-items: center;
    padding: 11px 20px;
    border-bottom: 1px solid rgba(255,255,255,.06);
    font-size: 12px;
  }

  .g-row:last-child { border-bottom: none; }

  .g-header {
    font-size: 10px;
    letter-spacing: .12em;
    color: rgba(255,255,255,.35);
    text-transform: uppercase;
    font-weight: 600;
    padding-top: 14px;
    padding-bottom: 14px;
    background: rgba(0,0,0,.2);
  }

  .g-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 8px;
    border-radius: 2px;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: .04em;
  }

  .g1 { background:rgba(57,255,138,.2); color:#39ff8a; }
  .g2 { background:rgba(162,255,57,.2); color:#a2ff39; }
  .g3 { background:rgba(251,191,36,.2); color:#fbbf24; }
  .g4 { background:rgba(249,115,22,.2); color:#f97316; }
  .g5 { background:rgba(248,113,113,.2); color:#f87171; }

  .g1-row { color: rgba(255,255,255,.75); }
  .g2-row { color: rgba(255,255,255,.72); }
  .g3-row { color: rgba(255,255,255,.70); }
  .g4-row { color: rgba(255,255,255,.68); }
  .g5-row { color: rgba(255,255,255,.66); }

  /* ── Places grid ── */
  .places-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .place-card {
    background: rgba(16,20,49,.85);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 3px;
    overflow: hidden;
    transition: border-color .3s, box-shadow .3s;
    backdrop-filter: blur(6px);
  }

  .place-card:hover {
    border-color: rgba(168,85,247,.7);
    box-shadow: 0 0 24px rgba(120,80,255,.2);
  }

  .place-photo-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .place-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(.75) saturate(1.3);
    transition: transform .4s, filter .4s;
  }

  .place-card:hover .place-photo-wrap img {
    transform: scale(1.04);
    filter: brightness(.9) saturate(1.5);
  }

  .place-body {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .place-flag-name {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .flag { font-size: 20px; }

  .place-flag-name h3 {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
  }

  .place-lat {
    font-size: 10px;
    color: var(--accent-cyan);
    letter-spacing: .05em;
  }

  .place-body p {
    font-size: 11px;
    color: rgba(255,255,255,.6);
    line-height: 1.55;
    flex: 1;
  }

  /* ── Photography guide ── */
  .photo-guide-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }

  .setting-card {
    background: rgba(16,20,49,.8);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 3px;
    padding: 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    backdrop-filter: blur(6px);
    text-align: center;
    transition: border-color .3s;
  }

  .setting-card:hover { border-color: var(--accent-cyan); }

  .setting-icon { font-size: 24px; }

  .setting-label {
    font-size: 9px;
    letter-spacing: .14em;
    color: rgba(255,255,255,.4);
    text-transform: uppercase;
    font-weight: 600;
  }

  .setting-value {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--accent-cyan);
    line-height: 1;
  }

  .setting-tip {
    font-size: 10px;
    color: rgba(255,255,255,.45);
    line-height: 1.4;
  }

  /* ── Resources ── */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: 14px;
    background: rgba(16,20,49,.8);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 3px;
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
    backdrop-filter: blur(6px);
    transition: border-color .3s, transform .2s;
  }

  .resource-link:hover {
    border-color: var(--accent-cyan);
    transform: translateY(-2px);
  }

  .resource-badge {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--accent-cyan);
    background: rgba(34,211,238,.1);
    border: 1px solid rgba(34,211,238,.3);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .resource-name {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }

  .resource-desc { font-size: 11px; color: rgba(255,255,255,.55); line-height: 1.5; }
  .resource-arrow { color: var(--accent-cyan); font-size: 16px; margin-left: auto; flex-shrink: 0; }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .science-grid       { grid-template-columns: repeat(2, 1fr); }
    .photo-guide-grid   { grid-template-columns: repeat(3, 1fr); }
    .places-grid        { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .photo-strip        { grid-template-columns: repeat(2, 1fr); }
    .science-grid       { grid-template-columns: 1fr; }
    .photo-guide-grid   { grid-template-columns: repeat(2, 1fr); }
    .places-grid        { grid-template-columns: 1fr; }
    .resources-grid     { grid-template-columns: 1fr; }
    .g-row              { grid-template-columns: 50px 1fr; font-size: 11px; gap: 8px; }
    .g-row span:nth-child(3),
    .g-row span:nth-child(4) { display: none; }
    .g-header span:nth-child(3),
    .g-header span:nth-child(4) { display: none; }
  }
</style>
