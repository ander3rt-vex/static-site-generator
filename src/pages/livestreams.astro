---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

// Four live streams matching Desktop-2's 2×2 grid
const streams = [
  {
    label:    'LIVESTREAMS',
    title:    'Aurora Borealis LIVE! — Lapland, Finland',
    location: '📍 Lapland, Finland · 68°N',
    desc:     '24/7 wilderness sky camera from remote Finnish Lapland. Updated continuously.',
    ytLink:   'https://www.youtube.com/channel/UCrEfDv09Q2suoiSDt1hZIlg',
    embedSrc: 'https://www.youtube.com/embed/live_stream?channel=UCrEfDv09Q2suoiSDt1hZIlg&autoplay=1&mute=1&modestbranding=1&rel=0',
    fallback: 'https://images.unsplash.com/photo-1531366936337-7c912a4589a7?auto=format&fit=crop&w=800&q=80',
    fallbackAlt: 'Aurora borealis over Lapland, Finland',
    live: true,
  },
  {
    label:    'LIVESTREAMS',
    title:    'Explore.org — Fairbanks, Alaska',
    location: '📍 Fairbanks, Alaska · 64°N',
    desc:     'UAF Geophysical Institute all-sky camera. Polar oval coverage, refreshed every 10 min.',
    ytLink:   'https://www.youtube.com/watch?v=O52zDyxg5QI',
    embedSrc: 'https://www.youtube.com/embed/O52zDyxg5QI?autoplay=1&mute=1&modestbranding=1&rel=0&loop=1&playlist=O52zDyxg5QI',
    fallback: 'https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=800&q=80',
    fallbackAlt: 'Aurora over Alaskan mountain range',
    live: true,
  },
  {
    label:    'LIVESTREAMS',
    title:    'North Dakota Dual Aurora Cameras',
    location: '📍 Inkster, North Dakota · 48°N',
    desc:     'NoDDAC citizen science project — dual north-facing cameras at Martens Observatory.',
    ytLink:   'https://www.youtube.com/channel/UC7pBM_HJbGO7IlYIAsFcKAg',
    embedSrc: 'https://www.youtube.com/embed/live_stream?channel=UC7pBM_HJbGO7IlYIAsFcKAg&autoplay=1&mute=1&modestbranding=1&rel=0',
    fallback: 'https://images.unsplash.com/photo-1566132127697-4524fea60007?auto=format&fit=crop&w=800&q=80',
    fallbackAlt: 'Aurora borealis in the night sky',
    live: false,
  },
  {
    label:    'LIVESTREAMS',
    title:    'NOAA OVATION — Aurora Oval',
    location: '🛰️ NOAA DSCOVR Satellite · L1 Point',
    desc:     'Real-time 30-min aurora oval probability forecast from NOAA. Public domain data.',
    ytLink:   'https://www.swpc.noaa.gov/communities/aurora-dashboard-experimental',
    embedSrc: '',   // uses NOAA image instead
    fallback: 'https://services.swpc.noaa.gov/images/animations/ovation/north/latest.jpg',
    fallbackAlt: 'NOAA OVATION aurora oval forecast — Northern Hemisphere',
    live: true,
    isMap: true,
  },
];
---

<Layout
  title="Livestreams"
  description="Live aurora camera streams from Lapland, Alaska, North Dakota, and NOAA's real-time aurora oval."
  bgImage={`${base}images/livestreams-bg.jpg`}
  activePage="livestreams"
>

  <!-- ═══════════════════════════════════════════════════
       2 × 2 STREAM GRID  (matches Figma Desktop-2 exactly)
       — 4 cards, 3px white border, label above each
  ═══════════════════════════════════════════════════ -->
  <div class="streams-wrapper">

    {streams.map((s, i) => (
      <div class="stream-unit">
        <!-- "LIVESTREAMS" label above each card — Figma has this text above every box -->
        <div class="stream-label-row">
          <span class="stream-label">{s.label}</span>
          {s.live
            ? <span class="badge badge-green"><span class="pulse-dot"></span>LIVE</span>
            : <span class="badge badge-purple">OFFLINE</span>
          }
        </div>

        <!-- Card — 3px solid white border matches Desktop-2 -->
        <div class={`stream-card ${s.isMap ? 'stream-card-map' : ''}`}>
          <div class="stream-embed">

            {/* Fallback / background photo */}
            <img
              src={s.fallback}
              alt={s.fallbackAlt}
              class={`stream-photo ${s.isMap ? 'stream-photo-map' : ''}`}
              loading={i < 2 ? 'eager' : 'lazy'}
              id={s.isMap ? 'noaa-oval' : undefined}
            />

            {/* YouTube iframe (skip for NOAA map card) */}
            {!s.isMap && (
              <iframe
                src={s.embedSrc}
                title={s.title}
                frameborder="0"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
                class="stream-iframe"
              ></iframe>
            )}
          </div>

          <!-- Card footer -->
          <div class="stream-footer">
            <span class="stream-loc">{s.location}</span>
            <span class="stream-desc">{s.desc}</span>
            <a class="stream-link" href={s.ytLink} target="_blank" rel="noopener">
              {s.isMap ? 'Open NOAA Dashboard →' : 'Watch on YouTube →'}
            </a>
          </div>
        </div>
      </div>
    ))}

  </div>

</Layout>

<style>
/* ═══════════════════════════════════════════════════
   STREAMS WRAPPER — 2×2 grid matching Desktop-2
═══════════════════════════════════════════════════ */
.streams-wrapper {
  position: relative;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28px 32px;
  padding: 28px 50px 56px;
}

/* Each "unit" = label row + card below */
.stream-unit {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ═══════════════════════════════════════════════════
   LABEL ROW  ("LIVESTREAMS" + live badge — Figma text above each card)
═══════════════════════════════════════════════════ */
.stream-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 8px;
}

.stream-label {
  font-family: var(--font-display);
  /* Figma: 64px — scale proportionally for web */
  font-size: clamp(24px, 3.5vw, 52px);
  letter-spacing: .04em;
  font-weight: 400;
  color: var(--white);
  line-height: 1;
  text-shadow: 0 2px 16px rgba(0,0,0,.6);
}

/* ═══════════════════════════════════════════════════
   STREAM CARD  — 3px solid white border (Desktop-2)
═══════════════════════════════════════════════════ */
.stream-card {
  background: var(--card);       /* #101431 */
  border: 3px solid var(--white); /* exact Figma spec */
  border-radius: 3px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color .3s, box-shadow .3s;
}

.stream-card:hover {
  border-color: rgba(95,55,180,.9);
  box-shadow: 0 0 36px rgba(95,55,180,.3);
}

/* 3:2 aspect — 496:331 from Figma */
.stream-embed {
  position: relative;
  width: 100%;
  padding-top: 66.73%;
  overflow: hidden;
  background: #060810;
}

/* Aurora photo as background layer */
.stream-photo {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(.65) saturate(1.3);
  z-index: 1;
  transition: filter .4s;
}

.stream-card:hover .stream-photo { filter: brightness(.75) saturate(1.5); }

/* Map photo (NOAA oval) — contain not cover, no dark filter */
.stream-photo-map {
  object-fit: contain;
  filter: saturate(1.5) brightness(1.1);
  padding: 8px;
  background: #060810;
}

.stream-card:hover .stream-photo-map { filter: saturate(1.7) brightness(1.2); }

/* YouTube iframe on top */
.stream-iframe {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  z-index: 2;
  border: none;
  opacity: 0;
  transition: opacity .7s;
}

.stream-iframe.loaded { opacity: 1; }

/* Card footer */
.stream-footer {
  padding: 12px 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stream-loc  { font-size: 11px; color: rgba(255,255,255,.4); letter-spacing: .04em; }
.stream-desc { font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.45; }

.stream-link {
  font-size: 11px;
  color: #78c42a;
  text-decoration: none;
  margin-top: 3px;
  letter-spacing: .03em;
  display: inline-block;
}

.stream-link:hover { text-decoration: underline; }

/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media (max-width: 900px) {
  .streams-wrapper { grid-template-columns: 1fr; padding: 24px 20px 48px; gap: 32px; }
}
</style>

<script>
  // Fade iframes in once loaded
  document.querySelectorAll('.stream-iframe').forEach(iframe => {
    iframe.addEventListener('load', () => iframe.classList.add('loaded'));
    setTimeout(() => iframe.classList.add('loaded'), 3500);
  });

  // Auto-refresh NOAA oval every 5 min
  const oval = document.getElementById('noaa-oval') as HTMLImageElement | null;
  if (oval) {
    setInterval(() => {
      const src = oval.src.split('?')[0];
      oval.src = `${src}?t=${Date.now()}`;
    }, 300_000);
  }
</script>
